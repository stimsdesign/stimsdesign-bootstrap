# PUBLIC ENVIRONMENT VARIABLES
# ---------------------------------------------------------
# Variables starting with `PUBLIC_` will be exposed to the 
# frontend browser. Do not place private secrets here.

# The base URL of your deployed application
PUBLIC_APP_URL="http://localhost:4321"

# DEVELOPMENT FLAGS
# ---------------------------------------------------------
# Set to TRUE to enable verbose logging in the console
ENABLE_DEBUG_LOGGING=FALSE

# Set to TRUE to redirect all traffic to the 503 Maintenance Page
ENABLE_MAINTENANCE_MODE=FALSE

# =========================================================
# 🔒 BACKEND SECRETS (Uncomment when mounting @stimsdesign/backend)
# =========================================================

# --- Database Connection ---
# DATABASE_URL=postgresql://user:pass@hostname/dbname?sslmode=require

# --- Better Auth Security Configuration ---
# BETTER_AUTH_SECRET=your_secure_random_string_32_chars_min
# BETTER_AUTH_URL=http://localhost:4321
# PUBLIC_BETTER_AUTH_URL=http://localhost:4321

# --- Social Provider Credentials ---
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# TWITTER_CLIENT_ID=your_twitter_client_id
# TWITTER_CLIENT_SECRET=your_twitter_client_secret

# --- Email Notifications (Resend) ---
# RESEND_API_KEY=re_your_resend_api_key
# SEND_EMAIL_FROM="STIMS Design <support@stimsdesign.com>"
# USE_ETHEREAL=TRUE

# --- STIMS API Route Security ---
# STIMSDESIGN_SECRET_KEY=stimsdesign
