---
import Template from '../layouts/BaseLayout.astro';
import Main from '../components/layout/Main.astro';
import Button from "../components/elements/Button.astro";
import EyeIcon from "../icons/eye.svg"
import EyeOffIcon from "../icons/eye-off.svg"
import { db } from "@stimsdesign/core/db";
import { logger } from "@stimsdesign/core/logger";

export const prerender = false;

const token = Astro.url.searchParams.get("token");
const emailFromUrl = Astro.url.searchParams.get("email");
let userName = "";
let userEmail = emailFromUrl || "";

if (emailFromUrl) {
    try {
        const { rows } = await db.query(`
            SELECT u.name, u.email
            FROM "user" u
            WHERE u.email = $1
        `, [emailFromUrl]);
        
        if (rows.length > 0) {
            userName = rows[0].name;
            userEmail = rows[0].email;
        }
    } catch (err) {
        logger.error("Error fetching user for password reset:", err);
    }
} else if (token) {
    // Fallback to token if email is missing (less reliable based on tests)
    try {
        const { rows } = await db.query(`
            SELECT u.name, u.email
            FROM "verification" v
            JOIN "user" u ON v.identifier = u.email
            WHERE v.value = $1 AND v."expiresAt" > NOW()
        `, [token]);
        
        if (rows.length > 0) {
            userName = rows[0].name;
            userEmail = rows[0].email;
        }
    } catch (err) {
        logger.error("Error fetching user by token:", err);
    }
}

---

<Template title="Password Reset | STIMS Design" description="">
	<Main>
        <div class="pwd-reset-wrapper">
            <section class="pwd-reset-card fancy-border">
                    <div class="pwd-reset-content">
                        <div class="login-column">
                            <h1>Password Reset</h1>
                            <p>Hello {userName || "there"}, use the form below to reset your password</p>
                            <div class="feedback" id="pwd-reset-message"></div>
                            <form id="reset-password-form" data-email={userEmail}>
                                <div class="form-group">
                                    <label for="new-password">New Password</label>
                                    <div class="password-input-wrapper">
                                        <input type="password" id="new-password" name="new-password" placeholder="••••••••" required />
                                        <button type="button" class="toggle-password" tabindex="-1" aria-label="Toggle password visibility">
                                            <span class="eye-open"><EyeIcon /></span>
                                            <span class="eye-closed"><EyeOffIcon /></span>
                                        </button>
                                    </div>                                
                                </div>
                                <div class="form-group">
                                    <label for="confirm-password">Confirm Password</label>
                                    <div class="password-input-wrapper">
                                        <input type="password" id="confirm-password" name="confirm-password" placeholder="••••••••" required />
                                        <button type="button" class="toggle-password" tabindex="-1" aria-label="Toggle password visibility">
                                            <span class="eye-open"><EyeIcon /></span>
                                            <span class="eye-closed"><EyeOffIcon /></span>
                                        </button>
                                    </div>                                
                                </div>
                                <div class="password-requirements small">
                                    Passwords must be <span class="req-characters">8 characters minimum</span>, <span class="req-uppercase">include an uppercase character</span>, <span class="req-number">include a number</span>, and <span class="req-special">include a special character</span>.
                                </div>
                                 <Button type="submit" margin="0 auto">Reset Password</Button>
                            </form>
                        </div>
                    </div>
            </section>
        </div>


	</Main>
</Template>

<style>
    .pwd-reset-wrapper {
        max-width: 800px;
        margin: 2rem auto 0;
    }

    .pwd-reset-content {
        padding: 4rem;
        background: var(--color-primary-darker);
        border-radius: inherit;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        position: relative;
        overflow: hidden;
    }

    .pwd-reset-header h1 {
        margin-bottom: 0.5rem;
        color: var(--color-foreground);
        text-shadow: 0 0 10px var(--color-secondary);
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .form-group label {
        font-size: var(--size-lg);
        font-weight: var(--weight-medium);
        color: var(--color-foreground);
    }

    .form-group input {
        padding: 1rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        color: white;
        transition: all 0.3s ease;
        font-size: var(--size-med);
        width: 100%;
    }

    .form-group input:focus {
        outline: none;
        border-color: var(--color-secondary);
        background: rgba(255, 255, 255, 0.08);
        box-shadow: 0 0 15px rgba(2, 76, 170, 0.3);
    }

    .password-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .password-input-wrapper input {
        padding-right: 3.5rem;
    }

    .toggle-password {
        position: absolute;
        right: 0.75rem;
        background: none;
        border: none;
        color: var(--color-foreground-dark);
        cursor: pointer;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.3s ease;
        z-index: 2;
    }

    .toggle-password:hover {
        color: var(--color-secondary);
    }

    .toggle-password svg {
        width: 20px;
        height: 20px;
    }

    .eye-closed {
        display: none;
    }

    .password-input-wrapper.show-password .eye-open {
        display: none;
    }

    .password-input-wrapper.show-password .eye-closed {
        display: block;
    }

    .password-requirements {
        flex-basis: 100%;
        margin:0 0 1.5rem;
    }

    /* Feedback Styles from DashboardLayout */
    .feedback {
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 5px;
        display: none;
        margin-bottom: 1.5rem;
    }
    .feedback.success {
        display: block;
        background: rgba(16, 185, 129, 0.1);
        color: #34d399;
        border: 1px solid #10b981;
    }
    .feedback.error {
        display: block;
        background: rgba(239, 68, 68, 0.1);
        color: #f87171;
        border: 1px solid #ef4444;
    }

</style>

<script>
    import { authClient } from "@stimsdesign/backend/utils/auth-client";
    import { navigate } from "astro:transitions/client";

    document.addEventListener("astro:page-load", () => {
        const resetForm = document.getElementById("reset-password-form") as HTMLFormElement;
        const passwordInput = document.getElementById("new-password") as HTMLInputElement;
        const confirmPasswordInput = document.getElementById("confirm-password") as HTMLInputElement;
        const messageContainer = document.getElementById("pwd-reset-message");

        function showMessage(message: string, isError = true) {
            if (messageContainer) {
                messageContainer.textContent = message;
                messageContainer.className = `feedback ${isError ? 'error' : 'success'}`;
                messageContainer.style.display = 'block';
            }
        }

        // Real-time Password Validation
        const validatePassword = (value: string) => {
            const reqs = {
                characters: value.length >= 8,
                uppercase: /[A-Z]/.test(value),
                number: /\d/.test(value),
                special: /[@$!%*?&#]/.test(value)
            };

            Object.entries(reqs).forEach(([key, valid]) => {
                const el = document.querySelector(`.req-${key}`);
                if (el) {
                    el.classList.toggle('active', valid);
                }
            });
        };

        if (passwordInput) {
            passwordInput.addEventListener('input', (e) => {
                validatePassword((e.target as HTMLInputElement).value);
            });
        }

        // Password Toggles
        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', () => {
                const wrapper = btn.closest('.password-input-wrapper');
                const input = wrapper?.querySelector('input');
                if (input) {
                    const isPassword = input.type === 'password';
                    input.type = isPassword ? 'text' : 'password';
                    wrapper?.classList.toggle('show-password', isPassword);
                }
            });
        });

        if (resetForm && passwordInput && confirmPasswordInput) {
            resetForm.addEventListener("submit", async (e) => {
                e.preventDefault();
                
                if (messageContainer) {
                    messageContainer.style.display = 'none';
                }

                if (passwordInput.value !== confirmPasswordInput.value) {
                    showMessage("Passwords do not match.", true);
                    return;
                }

                const password = passwordInput.value;
                const passwordRegex = /^(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&#])[A-Za-z\d@$!%*?&#]{8,}$/;
                if (!passwordRegex.test(password)) {
                    showMessage("Password does not meet requirements.", true);
                    return;
                }

                const urlParams = new URLSearchParams(window.location.search);
                const token = urlParams.get("token");

                if (!token) {
                    showMessage("Invalid or missing reset token. Please request a new link.", true);
                    return;
                }

                showMessage("Updating password...", false);

                // @ts-ignore
                const { error } = await authClient.resetPassword({
                    newPassword: password,
                    token: token
                });

                if (error) {
                    showMessage(error.message || "Failed to reset password. The link may have expired.", true);
                } else {
                    showMessage("Password reset successfully! Logging you in...", false);
                    
                    const email = resetForm.dataset.email;
                    if (email) {
                        // Log the user in automatically
                        const { error: loginError } = await authClient.signIn.email({
                            email,
                            password,
                        });

                        if (loginError) {
                            showMessage("Password reset, but failed to log in automatically. Please log in manually.", true);
                            setTimeout(() => navigate("/portal"), 3000);
                        } else {
                            setTimeout(() => navigate("/dashboard"), 1500);
                        }
                    } else {
                        // If we couldn't find the email, redirect to portal
                        setTimeout(() => navigate("/portal"), 2000);
                    }
                }
            });
        }
    });
</script>
