---
import Template from "../layouts/BaseLayout.astro";
import Main from "../components/layout/Main.astro";
import Button from "../components/elements/Button.astro";

const serviceCategories = [
	{
		id: "web-dev",
		title: "Web Dev & Design",
		icon: "/images/target.png",
		button: "Request a Proposal",
		description: "High-performance digital experiences built for results.",
		upsell: [
			"Your website is more than a digital business card; it’s a high-performance conversion engine. Prioritize the intersection of elite design and technical precision to ensure every visitor’s journey is frictionless, persuasive, and optimized for your bottom line.",
			"From blazing-fast load speeds to a mobile-first architecture that dominates search rankings, deploy digital foundations that don’t just look premium—they scale your revenue and professionalize your entire SMB presence.",
		],
		services: [
			{
				name: "Marketing & Conversion",
				details: "Landing pages • Brochure & Lead capture sites",
				blurb: "Drive immediate growth with precision-engineered lead capture systems designed for SMB conversion.",
			},
			{
				name: "E-Commerce Solutions",
				details: "Online storefronts • Subscriptions • Payments",
				blurb: "Professional storefronts that handle the heavy lifting, from inventory sync to secure global payments.",
			},
			{
				name: "Booking & Events",
				details: "Scheduling platforms • Ticketing • Calendars",
				blurb: "Automate your calendar and ticketing with integrated systems that eliminate manual scheduling errors.",
			},
			{
				name: "Real Estate",
				details: "Property listings • Agent sites • Virtual tours",
				blurb: "Showcase properties with high-impact visuals and lead-gen tools tailored for the local market.",
			},
			{
				name: "Community Engagement",
				details: "Membership sites • Forums • Directories",
				blurb: "Build your tribe with secure membership portals and searchable directories designed for engagement.",
			},
			{
				name: "Educational Training",
				details: "LMS platforms • Testing • Certification",
				blurb: "Monetize your expertise with robust training hubs and automated certification workflows.",
			},
		],
	},
	{
		id: "digital-solutions",
		title: "Digital Solutions",
		icon: "/images/compass.png",
		button: "Get a Project Bid",
		description: "Smart automation and strategy to fuel your growth.",
		upsell: [
			"Stop losing hours to manual bottlenecks and fragmented data. Intelligent workflow solutions integrate disparate systems into a cohesive, automated powerhouse that reclaims your team’s most valuable resource: time.",
			"By bridging the gap between your CRM, lead intake, and internal operations, establish a transparent operational environment where data flows seamlessly and focus can shift from management to growth.",
		],
		services: [
			{
				name: "Strategy & Consulting",
				details: "Web audits • Journey mapping • Roadmaps",
				blurb: "Expert guidance to identify digital gaps and build a long-term roadmap for sustainable growth.",
			},
			{
				name: "CRM Integrations",
				details: "Setup • Sales pipelines • Automation",
				blurb: "Synchronize your sales data across platforms to ensure no lead ever falls through the cracks.",
			},
			{
				name: "Workflow Automation",
				details: "Lead intake • Notifications • Routing",
				blurb: "Let your systems work for you with automated routing that keeps your team focused on sales, not entry.",
			},
			{
				name: "Customer Support",
				details: "AI chatbots • FAQ systems • Registration",
				blurb: "Enhance customer satisfaction with 24/7 automated support that resolves common queries instantly.",
			},
			{
				name: "Staff Support",
				details: "Knowledge bases • Portals • Training",
				blurb: "Empower your team with a centralized knowledge hub that reduces onboarding time and increases output.",
			},
			{
				name: "Internal Operations",
				details: "Dashboards • Intranets • SOP hubs",
				blurb: "Gain real-time visibility into your business metrics with custom-built operational dashboards.",
			},
		],
	},
	{
		id: "graphic-design",
		title: "Graphic Design",
		icon: "/images/creative.png",
		button: "Price Your Vision",
		description: "Expert visual storytelling and professional branding.",
		upsell: [
			"Command immediate authority with a visual identity that radiates world-class professionalism. Pivot beyond simple aesthetics to develop a strategic brand language that builds deep, enterprise-level trust with your target audience.",
			"Whether it’s high-impact marketing creative or consistent digital assets across every channel, get assurance that your brand remains unmistakable and premium at every touchpoint, setting you far apart from local competition.",
		],
		services: [
			{
				name: "Branding",
				details: "Logo design • Identity strategy • Business cards",
				blurb: "Develop a cohesive visual language that communicates authority and professionalism at every touchpoint.",
			},
			{
				name: "Marketing Creative",
				details: "Ads • Email templates • Infographics",
				blurb: "High-impact assets designed specifically to capture attention in crowded digital marketplaces.",
			},
			{
				name: "Social Content",
				details: "Templates • Channel branding • Reel visuals",
				blurb: "Stay consistent and premium across all socials with templates that make posting effortless.",
			},
			{
				name: "UI/UX Design",
				details: "Web/Mobile app design • Wireframes • Flows",
				blurb: "Frictionless digital interfaces that prioritize user experience and drive desired user actions.",
			},
			{
				name: "Digital Assets",
				details: "Hero visuals • Icons • Video production",
				blurb: "Bespoke digital content that elevates your site from generic to a world-class experience.",
			},
			{
				name: "Copywriting",
				details: "Website copy • Blogs • Descriptions",
				blurb: "Compelling narrative work that resonates with your target audience and drives them to take action.",
			},
		],
	},
];

const packages = [
	{
		name: "Starter",
		id: "starter",
		price: "1,700",
		subtitle:
			"Perfect for solopreneurs and small shops requiring a reliable, professional foundation with essential monthly maintenance.",
		features: [
			"Website Hosting + Maintenance",
			"Monthly Analytics & SEO Check",
			"4 Custom Social Media Graphics",
			"2 Print or Digital Assets",
			"Up to 15 Service Hours",
		],
		highlighted: false,
	},
	{
		name: "Growth",
		id: "growth",
		price: "3,200",
		subtitle:
			"Designed for established SMBs ready to scale operations, dominate SEO results, and professionalize their brand output.",
		features: [
			"All Starter Assets Included",
			"Website UX Improvements",
			"3 Additional Print/Digital Assets",
			"2 SEO-Optimized Blog Articles",
			"1 Email Newsletter Design",
			"48–72h Request Turnaround",
			"Up to 30 Service Hours",
		],
		highlighted: true,
	},
	{
		name: "Premium",
		id: "premium",
		price: "5,800",
		subtitle:
			"Strategic leadership for high-growth enterprises and established companies requiring on-demand scaling and digital dominance.",
		features: [
			"All Growth Assets Included",
			"New Website Build/Redesign",
			"1 Microsite or Landing Page",
			"6 Additional Social Graphics",
			"5 Additional Print/Digital Assets",
			"1 Monthly Video Production",
			"On-call Creative Support",
			"24–48h Request Turnaround",
			"Up to 50 Service Hours",
		],
		highlighted: false,
	},
];
---

<Template title="Pricing & Services | STIMS Design" description="Explore high-impact digital services and fair pricing packages designed specifically for small and medium-sized businesses.">
	<Main>
		<div class="services-page-container">
			<header class="hero-header">
				<div class="hero-content">
					<h1 class="main-title"><span>Tailored Solutions</span> <span class="electric">&amp; Fair Pricing</span></h1>
					<p class="sub-heading text-center">	Streamline your business with smart automation, AI integrations, and optimized customer experiences with high-end design and transparent monthly support.</p>
				</div>
			</header>

			<section id="services" class="services-rows-section">
				<hgroup class="section-title">
					<h4>Core Service <span>Expertise</span></h4>
					<p class="electric indent">Specialized solutions organized for clarity and impact.</p>
				</hgroup>

				<div class="categories-list">
					{
						serviceCategories.map((cat) => (
							<div id={cat.id} class="category-row glass">
								<div class="category-info">
									<div class="cat-header">
										<div class="icon-wrap">
											<Fragment set:html={cat.icon.endsWith(".png") ? `<img src="${cat.icon}" alt="" />` : ""} />
										</div>
										<h3>{cat.title}</h3>
									</div>
									{cat.upsell.map((p) => (
										<p class="cat-upsell">{p}</p>
									))}
									<Button href={`/estimate.html#${cat.id}`}>
										{cat.button}
									</Button>
								</div>

								<div class="service-table-wrap">
									<div class="table-header">
										<span class="th">Key Service</span>
										<span class="th">Deliverables</span>
									</div>
									<div class="table-rows">
										{cat.services.map((ser) => (
											<Fragment>
												<div class="service-row">
													<span class="ser-name">{ser.name}</span>
													<span class="ser-details">{ser.details}</span>
												</div>
												<div class="service-blurb-row">
													<div class="blurb-content">
														{ser.blurb}
													</div>
												</div>
											</Fragment>
										))}
									</div>
								</div>
							</div>
						))
					}
				</div>
			</section>
		</div>

		<section id="pricing" class="pricing-grid-section">
			<div class="section-title">
				<h2 class="fire">Retainer <span>Packages</span></h2>
				<p class="subtitle">Monthy Commitments to You, <strong>Not Limitations</strong>, with No Hidden Fees.</p>
				<p>No Contracts, Start and Stop Service at Any Time.</p>
			</div>

			<div class="packages-container">
				{
					packages.map((pkg) => (
						<div class={`package-card ${pkg.highlighted ? "fancy-border" : ""}`}>
							<div class="pkg-inner">
								{pkg.highlighted && (
									<div class="status-pill">
										<span class="fire">Most Popular</span>
									</div>
								)}
								<div class="pkg-header">
									<h3>{pkg.name}</h3>
									<div class="price-wrap">
										{pkg.id === "premium" && (
											<span class="starts">Starting at&nbsp;</span>
										)}
										<span class="currency">$</span>
										<span class="amount">{pkg.price}</span>
										<span class="per">/mo</span>
									</div>
									<p class="subtitle">{pkg.subtitle}</p>
								</div>
								<ul class="pkg-features">
									{pkg.features.map((feat) => (
										<li class="check">{feat}</li>
									))}
								</ul>
								<div class="pkg-footer">
									<a href={`/estimate.html#${pkg.id}`} class="pkg-btn">Choose {pkg.name}</a>
								</div>
							</div>
						</div>
					))
				}
			</div>

			<div class="onetime-builds glass">
				<div class="build-content">
					<hgroup>
						<h3>New Website Builds</h3>
						<span>Starting at <strong>$1,500</strong><small>*</small></span>
						<span>Costs Based on Project Scope</span>
					</hgroup>
					<Button href="/estimate.html#onetime-builds">Click Here to Get Started!</Button>
					<ul>
						<li>Landing Pages</li>
						<li>Storefronts</li>
						<li>Blogs</li>
						<li>Brochures</li>
						<li>Lead Capture Funnels</li>
						<li>Portfolios</li>
						<li>Corporate Portals</li>
						<li>Subscription Services</li>
						<li>Event Websites</li>
						<li>Non-Profits</li>
						<li>Microsites</li>
						<li>Listing Directories</li>
						<li>Online Communities</li>
						<li>Educational Courses</li>
						<li>Appointment Setting</li>
						<li>SaaS Platforms</li>
						<li>Real Estate Portals</li>
						<li>Job Boards</li>
						<li>Knowledge Bases</li>
						<li>News & Media Sites</li>
						<li>Internal Dashboards</li>
					</ul>
					<p class="terms">*<strong>50% Deposit and 50% Final Payment</strong> on completion per project. Each project receives a custom quote based on scope.</p>
				</div>
			</div>
		</section>
	</Main>
</Template>

<style>
	/* Premium Page Container */
	.services-page-container {
		max-width: clamp(94%, 100% - 10cqi, 1440px);
		margin: 0 auto;
		color: var(--color-foreground);
	}

	/* Glassmorphism Base */
	.glass {
		background: color-mix(
			in srgb,
			var(--color-primary-dark),
			transparent 50%
		);

		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 24px;
		box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
	}

	@media (max-width: 768px) {
		.glass {
			background: var(--color-primary-dark);
			box-shadow: none;
		}
	}

	/* Hero Styling */
	.hero-header {
		padding: 3rem 0;
		text-align: center;
	}

	@media (max-width: 768px) {
		.hero-header {
			padding: 0 2rem 2rem;
		}
	}

	.hero-content .main-title {
		font-size: var(--size-4xl);
		line-height: 1.1;
		margin-bottom: 0.5rem;
		color: var(--color-foreground);
		font-weight: var(--weight-black);
	}

	.hero-content .main-title span:first-child {
		filter: drop-shadow(1px 1px 4px rgba(255, 255, 255, 0.4));
	}

	.hero-content .accent-line {
		display: block;
		font-size: 0.6em;
		color: var(--color-accent-light);
	}

	.hero-content .sub-heading {
		max-width: 80ch;
		margin: 0.5rem auto 0;
		font-size: var(--size-lg);
		line-height: 1.6;
		padding: 0 1rem;
	}

	.text-center {
		text-align: center;
	}

	#services {
		padding: 1rem 2rem 2rem;
		background-color: var(--color-background);
		border-radius: 24px;
		background-image: url("/images/homehero-bg.svg");
		background-repeat: no-repeat;
		background-size: cover;

		margin-bottom: 6rem;
	}

	@media (max-width: 768px) {
		#services {
			padding: 2rem 0.5em;
			margin-bottom: 3rem;
		}
	}

	/* Section Headers */
	.section-title {
		margin: 3rem 0;
	}

	.section-title h4 {
		margin-bottom: 0.25rem;
		text-transform: uppercase;
	}

	.section-title h4 span {
		color: var(--color-accent);
	}

	@media (max-width: 768px) {
		.section-title {
			margin: 0;
			text-align: center;
		}
	}

	/* Services List (Horizontal Rows) */
	.services-rows-section {
		padding: 0 0;
	}

	.services-rows-section .categories-list {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.services-rows-section .category-row {
		padding: 3.5rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		transition: border-color 0.3s ease;
	}

	@media (min-width: 1400px) {
		.services-rows-section .category-row {
			grid-template-columns: 1fr 3fr;
			align-items: start;
			gap: 3.5rem;
		}
	}

	@media (max-width: 768px) {
		.services-rows-section .category-row {
			padding: 0;
		}
	}

	.services-rows-section .category-row:hover {
		border-color: var(--color-primary-light);
	}

	.cat-header {
		display: flex;
		gap: 1.25rem;
		margin-bottom: 1rem;
		align-items: center;
	}

	@media (max-width: 768px) {
		.cat-header {
			justify-content: center;
		}

		.category-info {
			text-align: center;
			padding: 0 1rem;
		}
	}

	.cat-header h3 {
		font-family: var(--family-base);
	}

	#web-dev .cat-header h3 {
		color: var(--color-accent-lighter);
	}

	#digital-solutions .cat-header h3 {
		color: var(--color-secondary-light);
	}

	#graphic-design .cat-header h3 {
		color: var(--color-foreground);
	}

	.icon-wrap {
		width: 72px;
		height: 72px;
		background: transparent;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.icon-wrap img {
		width: 64px;
		height: 64px;
		object-fit: contain;
	}

	.cat-header h3 {
		margin: 0;
		font-size: var(--size-xl);
		color: var(--color-foreground);
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.cat-upsell {
		color: var(--color-foreground-light);
		line-height: 1.5;
		margin-bottom: 2em;
	}

	@media (max-width: 768px) {
		.cat-upsell {
			margin-bottom: 1em;
		}
	}

	/* Custom Table Style */
	.service-table-wrap {
		background: var(--color-primary-dark);
		border-radius: 20px;
		overflow: hidden;
		border: 1px solid var(--color-primary-dark);
	}

	.table-header {
		display: grid;
		grid-template-columns: 1.2fr 2.5fr;
		background: var(--color-background);
		padding: 1.5rem 2.5rem;
		border-bottom: 1px solid var(--color-primary);
	}

	.th {
		text-transform: uppercase;
		font-weight: var(--weight-bold);
		letter-spacing: 1.5px;
	}

	#web-dev .th {
		color: var(--color-accent-lighter);
	}

	#digital-solutions .th {
		color: var(--color-secondary-light);
	}

	#graphic-design .th {
		color: var(--color-foreground-light);
	}

	.service-row {
		display: grid;
		grid-template-columns: 1.2fr 2.5fr;
		padding: 1.75rem 2.5rem 0.75rem;
		text-transform: uppercase;
	}

	.ser-name {
		font-weight: var(--weight-bold);
		color: var(--color-foreground-lighter);
	}

	.ser-details {
		color: var(--color-foreground-lighter);
		line-height: 1.4;
	}

	.service-blurb-row {
		padding: 0 2.5rem 1.5rem;
		border-bottom: 2px solid var(--color-primary-darker);
	}

	@media (max-width: 768px) {
		.service-blurb-row {
			border-bottom: none;
		}
	}

	.service-row:last-of-type + .service-blurb-row {
		border-bottom: none;
	}

	.blurb-content {
		padding: 1rem 1.5rem;
		background: rgba(255, 255, 255, 0.02);
		border-radius: 0 8px 8px 0;
		font-size: var(--size-sm);
		color: var(--color-foreground-dark);
		font-style: italic;
		line-height: 1.5;
	}

	#web-dev .blurb-content {
		border-left: 3px solid var(--color-accent-lighter);
	}

	#digital-solutions .blurb-content {
		border-left: 3px solid var(--color-secondary-light);
	}

	#graphic-design .blurb-content {
		border-left: 3px solid var(--color-foreground-light);
	}

	/* Pricing Section */
	#pricing {
		max-width: clamp(94%, 100% - 10cqi, 1440px);
		margin: 0 auto;
		padding: 1rem 0;
	}

	#pricing .section-title {
		text-align: center;
		margin-bottom: 6rem;
	}

	#pricing .section-title h2 {
		font-size: var(--size-4xl);
		font-weight: var(--weight-bold);
		line-height: 1.1;
		margin-bottom: 0.5rem;
	}

	@media (max-width: 768px) {
		#pricing .section-title {
			margin-bottom: 2dvh;
		}
	}

	#pricing .section-title p {
		margin: 0 auto;
		font-size: var(--size-lg);
	}

	.pricing-grid-section {
		margin-bottom: 4rem;
	}

	.packages-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
		gap: 2.5rem;
		margin-bottom: 4rem;
	}

	@media (max-width: 768px) {
		.packages-container {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}

	.package-card {
		padding: 0;
		position: relative;
	}

	.package-card.fancy-border {
		border-radius: 35px;
		scale: 1.025;
	}

	@media (max-width: 768px) {
		.package-card.fancy-border {
			scale: 1;
		}
	}

	.pkg-inner {
		padding: 2.5rem;
		height: 100%;
		display: flex;
		flex-direction: column;
		background-color: var(--color-background);
		background-image: url("/images/homehero-bg.svg");
		background-repeat: no-repeat;
		background-position: left;
		border-radius: 35px;
	}

	.fancy-border .pkg-inner {
		margin: 2px;
		background-position: center;
	}
	.package-card:nth-child(3) .pkg-inner {
		background-position: right;
	}

	.status-pill {
		position: absolute;
		top: -1rem;
		left: -1rem;
		font-size: var(--size-lg);
		font-weight: var(--weight-black);
		text-transform: uppercase;
		transform: rotate(-5deg);
		z-index: 10;
		pointer-events: none;
	}

	@media (max-width: 768px) {
		.status-pill {
			left: 50%;
			top: 0;
			transform: translateX(-50%) translateY(-50%) rotate(-5deg);
			font-size: var(--size-xl);
			white-space: nowrap;
		}
	}

	.pkg-header h3 {
		font-size: var(--size-xl);
		color: var(--color-secondary-lighter);
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.price-wrap {
		display: flex;
		align-items: center;
		gap: 0.2rem;
		margin-bottom: 1rem;
	}

	.price-wrap .currency {
		color: var(--color-accent);
		font-weight: var(--weight-bold);
	}

	.price-wrap .amount {
		font-size: var(--size-2xl);
		font-weight: var(--weight-bold);
		color: white;
	}

	.price-wrap .per {
		color: var(--color-foreground-dark);
		font-size: 1.2rem;
	}

	.pkg-header .subtitle {
		color: var(--color-foreground-light);
		line-height: 1.5;
		margin-bottom: 2rem;
	}

	.pkg-features {
		list-style: none;
		padding: 0;
		margin: 0 0 1rem;
	}

	.pkg-features li {
		margin-bottom: 1rem;
		color: var(--color-foreground-lighter);
		display: flex;
		align-items: center;
	}

	.pkg-footer {
		margin-top: auto;
	}

	.pkg-btn {
		display: block;
		width: 100%;
		padding: 1.2rem;
		text-align: center;
