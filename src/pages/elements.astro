    <Main id="elements-page">
        <PageHeading 
            fuzzy="https://unsplash.it/640/360?image=408"
            background="https://unsplash.it/2560/1440?image=408" 
            backgroundWidth={2560}
            backgroundHeight={1440}
            text="Elements Page"
        />
