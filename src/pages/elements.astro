---
// Components
import PageHeading from "@elements/PageHeading.astro";
import Modal from "@elements/Modal.astro";
import Button from "@elements/Button.astro";

// Layouts
import Template from "@layouts/ContentPage.astro";
import Main from "@layout/Main.astro";
import FooterContact from "@sections/FooterContact.astro";
---
