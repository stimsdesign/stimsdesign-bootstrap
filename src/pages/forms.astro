---
// Assets
import { Site } from "@site.config";

// Layouts
import Template from "@layouts/ContentPage.astro";
import Main from "@layout/Main.astro";

// Components   
import PageHeading from "@elements/PageHeading.astro";
import Button from "@elements/Button.astro";

// Inputs
import StepIndicator from "@forms/StepIndicator.astro";
import TextInput from "@forms/TextInput.astro";
import TextArea from "@forms/TextArea.astro";
import FileInput from "@forms/FileInput.astro";
import SelectInput from "@forms/SelectInput.astro";
import CheckboxGroup from "@forms/CheckboxGroup.astro";
import RadioGroup from "@forms/RadioGroup.astro";
import PillOption from "@forms/PillOption.astro";
import DynamicInputWrapper from "@forms/DynamicInputWrapper.astro";
import Quantity from "@forms/Quantity.astro";
import Honeypot from "@forms/Honeypot.astro";
import NameInput from "@forms/NameInput.astro";
import EmailInput from "@forms/EmailInput.astro";
import PhoneInput from "@forms/PhoneInput.astro";
//import Password from "@forms/Password.astro";
import CreatePassword from "@forms/CreatePassword.astro";
import SelectTime from "@forms/SelectTime.astro";
import DatePicker from "@forms/DatePicker.astro";
import SelectDay from "@forms/SelectDay.astro";
import CompanyInput from "@forms/CompanyInput.astro";
// import AddressInput from "@forms/AddressInput.astro";
// import Address2Input from "@forms/Address2Input.astro";
// import CityInput from "@forms/CityInput.astro";
// import StateInput from "@forms/StateInput.astro";
// import ZipInput from "@forms/ZipInput.astro";
import ValidAddress from "@forms/ValidAddress.astro";

---
<Template title="Form Examples">
    <Main id="form-examples-page">
        <h1>Form Examples</h1>
        <div class="form-wrapper">
            <div class="form-card">
                <form 
                    id="example-form" 
                    class="contact-form multi-part-form" 
                    name="Example Form" 
                    data-netlify="true" 
                    netlify-honeypot="question-field"
                    data-modal-header="Email Sent"
                    data-modal-paragraph="Your message has been received. We will get back to you shortly."
                    data-modal-button="Close"
                    data-multi-part="true"
                    data-section-ids="section-1,section-2"
                >
                    <input type="hidden" name="form-name" value="Footer Contact Form" />
                    <input type="hidden" name="subject" value={`Footer Contact Submission from ${Site.PrettyUrl}`} />
                    <Honeypot />

                    <StepIndicator stepTotal={2} />

                    <div id="section-1" class="form-section">
                        <div class="form-row">
                            <NameInput id="example-name" label="Your Name" tabindex={1} />
                            <EmailInput id="example-email" tabindex={2} />
                        </div>
                        <PhoneInput id="example-phone" tabindex={3} />
                        <CompanyInput id="example-company" tabindex={4} />
                        <!-- <DatePicker id="example-date" label="Preferred Date" days="sun,Tues,wed,thurs,Saturday" weekends={false} startRange={7} endRange={30} /> -->
                        <DatePicker id="example-date" label="Preferred Date" days="Monday, Tuesday, Wednesday, Thursday" endRange={90} excludedDates="05/07/26, 05/05/26" hideDays disableHistory tabindex={5} />
                        <SelectDay id="example-day" label="Select Day" days="Monday, Tuesday, Wednesday, Thursday" hideDays weekView disableHistory tabindex={6} />
                        <div class="buttons-group">
                            <Button type="reset" tabindex="-1">Reset</Button>
                            <Button class="next-btn" tabindex={7}>Next</Button>
                        </div>
                    </div>
                    <div id="section-2" class="form-section">
                        <ValidAddress id="test-address" provider="photon" tabindex={8} />
                        <TextArea id="example-message" label="Your Message" tabindex={9} />
                        <Quantity id="example-quantity" label="Quantity" min="1" max="10" tabindex={10} />
                        <CreatePassword form-row="true" tabindex={11} />
                        <SelectTime id="example-time" label="Preferred Time" increment={15} startTime="10:00" endTime="12:00" format={12} tabindex={12} />
                        <FileInput id="example-file" label="Upload File" tabindex={13} />
                        <div class="form-row">
                            <SelectInput id="service" label="Select Label" tabindex={14} options={[
                                { label: "Web Design", value: "web-design" },
                                { label: "Web Development", value: "web-development" },
                                { label: "SEO", value: "seo" },
                                { label: "Content Writing", value: "content-writing" }
                            ]} />
                            <SelectInput id="options" label="Select Label" tabindex={15} options={[
                                { label: "Option 1", value: "option1" },
                                { label: "Option 2", value: "option2" },
                                { label: "Option 3", value: "option3" }
                            ]} />
                        </div>
                        <div class="form-row">
                            <CheckboxGroup legend="Checkboxes" tabindex={16} list options={[
                                { id: "checkbox1", label: "Checkbox 1", value: "check1", required: true },
                                { id: "checkbox2", label: "Checkbox 2", value: "check2", required: true },
                                { id: "checkbox3", label: "Checkbox 3", value: "check3", required: true }
                            ]} />
                            <RadioGroup legend="Radios" tabindex={17} name="radio" options={[
                                { id: "radio1", label: "Radio 1", value: "rad1", required: true },
                                { id: "radio2", label: "Radio 2", value: "rad2", required: true },
                                { id: "radio3", label: "Radio 3", value: "rad3", required: true }
                            ]} />
                        </div>
                        <DynamicInputWrapper trigger="dynamic-example">
                            <div class="form-row">
                                <SelectInput id="dynamic-example" label="Select Label" tabindex={18} options={[
                                    { label: "Show Text Field", value: "Picked Dynamic Text", target: "dynamic1" },
                                    { label: "Show Select Field", value: "Picked Dynamic Select", target: "dynamic2" },
                                ]} />
                                <TextInput id="dynamic1" label="Dynamic Text" tabindex={18} />
                                <SelectInput id="dynamic2" label="Dynamic Select" defaultValue="Dynamic Select" tabindex={18} options={[
                                    { label: "Dynamic 1", value: "Dynamic 1" },
                                    { label: "Dynamic 2", value: "Dynamic 2" },
                                    { label: "Dynamic 3", value: "Dynamic 3" }
                                ]} />
                            </div>
                        </DynamicInputWrapper>
                        <PillOption id="pill" label="Join our mailing list for updates and special offers" name="mailing-list" tabindex={19} />
                        <div class="buttons-group">
                            <Button class="prev-btn" tabindex="-1">Previous</Button>
                            <Button type="submit" tabindex={20}>Submit</Button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </Main>
</Template>

<style>
    .form-wrapper {
        width: 90%;
        max-width: 1000px;
        margin: 50px auto;
    }
</style>

<script>
    import { FormHandler } from "@scripts/FormHandler.js";
    document.addEventListener("astro:page-load", () => {
        document.querySelectorAll(".contact-form").forEach((formEl) => {
            new FormHandler(formEl as HTMLFormElement);
        });
    });
</script>
