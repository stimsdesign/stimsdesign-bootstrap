---
import Template from '../layouts/BaseLayout.astro';
import Main from '../components/layout/Main.astro';
---

<Template title="404 - Page Not Found | STIMS Design" description="">
	<Main>
		<div id="fourofour">
			<h1>404 - Page Not Found</h1>
			<p>Sorry, the page you are looking for does not exist.</p>
		</div>
	</Main>
</Template>

<style>
	#fourofour {
		text-align: center;
		padding: 6rem 2rem;
	}

	#fourofour h1 {
		margin-bottom: 1rem;
		filter: drop-shadow(1px 1px 4px rgba(255, 255, 255, 0.4));
	}

	#fourofour p {
		font-size: 1.5rem;
		margin: 0 auto;
		color: var(--color-text-secondary);
	}
</style>