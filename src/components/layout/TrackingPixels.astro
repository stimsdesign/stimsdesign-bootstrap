---
// Import Config
import { Site } from "@site.config";
---
{/* Google Tag Manager (GTM) Initialization */}
{Site.GoogleTagManager && Site.GoogleTagManager.trim().length > 0 && (
    <script is:inline set:html={`
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','${Site.GoogleTagManager}');
    `} />
)}

{/* Google Analytics 4 (GA4 gtag) Initialization */}
{Site.GoogleAnalytics && Site.GoogleAnalytics.trim().length > 0 && (
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${Site.GoogleAnalytics}`}></script>
)}
{Site.GoogleAnalytics && Site.GoogleAnalytics.trim().length > 0 && (
    <script is:inline define:vars={{ gaId: Site.GoogleAnalytics }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId, { send_page_view: false });
    </script>
)}

{/* Meta (Facebook) Pixel Initialization */}
{Site.MetaPixel && Site.MetaPixel.trim().length > 0 && (
    <script is:inline define:vars={{ pixelId: Site.MetaPixel }}>
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window,document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', pixelId);
    </script>
)}

{/* LinkedIn Insight Tag Initialization */}
{Site.LinkedInInsight && Site.LinkedInInsight.trim().length > 0 && (
    <script is:inline define:vars={{ partnerId: Site.LinkedInInsight }}>
        _linkedin_partner_id = partnerId;
        window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
        window._linkedin_data_partner_ids.push(_linkedin_partner_id);
        (function(l) {
        if (!l) {window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
        window.lintrk.q=[]}
        var s = document.getElementsByTagName("script")[0];
        var b = document.createElement("script");
        b.type = "text/javascript";b.async = true;
        b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
        s.parentNode.insertBefore(b, s);})(window.lintrk);
    </script>
)}

{/* Unified Event Dispatcher & Subscribers for Astro ClientRouter */}
<script>
    import { Site } from "@site.config";

    let isFirstLoad = true;

    document.addEventListener("astro:page-load", () => {
        window.dispatchEvent(new CustomEvent("app:pageview", {
            detail: {
                path: window.location.pathname,
                title: document.title,
                referrer: document.referrer,
                isFirstLoad
            }
        }));
        isFirstLoad = false;
    });

    // 1. GTM Pageview Dispatch
    if (Site.GoogleTagManager && Site.GoogleTagManager.trim().length > 0) {
        window.addEventListener("app:pageview", (e) => {
            const { path, title, isFirstLoad: initial } = (e as CustomEvent).detail;
            if (!Site.GtmSpaMode && initial) return;

            const globalWindow = window as any;
            globalWindow.dataLayer = globalWindow.dataLayer || [];
            globalWindow.dataLayer.push({
                event: "gtm.pageview",
                pagePath: path,
                pageTitle: title
            });
        });
    }

    // 2. Google Analytics 4 Dispatch
    if (Site.GoogleAnalytics && Site.GoogleAnalytics.trim().length > 0) {
        window.addEventListener("app:pageview", (e) => {
            const { path, title } = (e as CustomEvent).detail;
            const globalWindow = window as any;
            if (typeof globalWindow.gtag === "function") {
                globalWindow.gtag("event", "page_view", {
                    page_path: path,
                    page_title: title
                });
            }
        });
    }

    // 3. Meta Pixel Dispatch
    if (Site.MetaPixel && Site.MetaPixel.trim().length > 0) {
        window.addEventListener("app:pageview", () => {
            const globalWindow = window as any;
            if (typeof globalWindow.fbq === "function") {
                globalWindow.fbq("track", "PageView");
            }
        });
    }

    // 4. LinkedIn Insight Dispatch
    if (Site.LinkedInInsight && Site.LinkedInInsight.trim().length > 0) {
        window.addEventListener("app:pageview", () => {
            const globalWindow = window as any;
            if (typeof globalWindow.lintrk === "function") {
                globalWindow.lintrk("track");
            }
        });
    }
</script>
