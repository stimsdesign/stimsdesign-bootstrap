---
import { siteConfig } from "../../siteConfig";
import Logo from "../elements/Logo.astro";
const linksTitle = "Quick Links";
const links = [
    { name: "Home", href: "/", icon: null },
    { name: "Contact", href: "/contact.html", icon: null },
];
---
<footer>
    <div class="footer-grid">
        <div class="footer-col brand-col">
            <Logo src={siteConfig.logoAlt} height="60px" />
            <p class="brand-mission">{siteConfig.mission}</p>
            <div class="social-links">
                {siteConfig.socialLinks.map((link) => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.name}><link.icon /></a>
                ))}
            </div>
        </div>
        <div class="footer-col link-col">
            <h6>{linksTitle}</h6>
            <ul class="footer-links">
                {links.map((link) => (
                    <li><a href={link.href}>{link.name}{link.icon && <link.icon />}</a></li>
                ))}
            </ul>
        </div>
        <div class="footer-col link-col">
            <h6>{linksTitle}</h6>
            <ul class="footer-links">
                {links.map((link) => (
                    <li><a href={link.href}>{link.name}{link.icon && <link.icon />}</a></li>
                ))}
            </ul>
        </div>
        <div class="footer-col extras-col">
            <h6>Extras</h6>
        </div>
    </div>
    <div class="footer-copy">
        <p class="copyright">©{new Date().getFullYear()} {siteConfig.company}</p>
    </div>
</footer>

<style is:global>
    footer {
        display: flex;
        flex-direction: column;
        position: relative;
    }

    .footer-grid {
        width: var(--desktop-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr;
        gap: 4rem;
    }

    /* Brand Column */
    .brand-col {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .logo-area {
        width: fit-content;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .brand-mission {
        font-size: var(--size-sm);
        max-width: 35ch;
    }

    .social-links {
        display: flex;
        gap: 1.25rem;
        text-align: center;
    }

    .social-links svg {
        color: var(--color-accent);
        transition:
            color 0.3s ease,
            transform 0.3s ease;
        width: 35px;
        height: 35px;
    }

    .social-links svg:hover {
        color: var(--color-accent-light);
        transform: translateY(-3px);
    }


    /* Links */
    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .footer-links a {
        color: var(--color-foreground);
        text-decoration: none;
        transition:
            color 0.3s ease,
            padding-left 0.3s ease;
        font-size: var(--size-sm);
        display: block;
    }

    .footer-links a:hover {
        color: var(--color-foreground-light);
        padding-left: 5px;
    }



    /* Bottom Bar */
    .footer-copy {
        width: var(--desktop-width);
        margin: 0 auto;
        padding: 1.5rem 0;
        font-size: var(--size-xs);
    }

    /* Responsive */
    @media (max-width: 1200px) {
        .footer-grid {
            grid-template-columns: 1.5fr 1fr 1fr;
        }
        .extras-col {
            grid-column: span 3;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }
    }

    @media (max-width: 767px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
            text-align: center;
        }

        .logo-area {
            width: auto;
        }

        .brand-col {
            grid-column: span 2;
        }

        .brand-mission {
            max-width: 100%;
        }

        .extras-col {
            grid-column: span 2;
            display: block; /* Remove the 3-column grid for mobile */
            text-align: center;
        }

        .social-links {
            justify-content: center;
        }
    }

    @media (max-width: 600px) {
        .footer-grid {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .brand-col, .link-col, .extras-col {
            grid-column: span 1;
        }
    }
</style>