            background-size: contain;
            background-repeat: no-repeat;
            background-position: right center;
        }
        .phone-link span {
            display: none;
        }
    }

    .wrapper a.logo {
        width: fit-content;
        display: inline-block;
        transform: translateY(-0.5rem);
    }
</style>