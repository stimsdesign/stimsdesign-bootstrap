---
/*************************************************************************
 * @forms/CheckboxGroup.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A fieldset grouping multiple checkbox inputs with standard layout, legend, 
 *  and dynamic conditional target display.
 * 
 * Usage:
 *  <CheckboxGroup 
 *      legend="Select Services" 
 *      list={true} 
 *      options={[
 *          { id: "web", label: "Web Design", value: "web-design", checked: true },
 *          { id: "seo", label: "SEO Services", value: "seo" }
 *      ]} 
 *  />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/CheckboxGroup.css";

// Props
interface Props {
    /** Visual accessibility title for the fieldset group. */
    legend: string;
    /** Array of checkbox option objects: { id, label, value, name?, required?, target?, checked? }. */
    options: { id: string; label: string; value: string; name?: string; required?: boolean; target?: string; checked?: boolean }[];
    /** If true, renders the checkbox options vertically in a list format. Default is false. */
    list?: boolean;
    /** Tabindex offset for keyboard navigation. */
    tabindex?: number;
}

// Destructuring Props
const { legend, options, list = false, tabindex } = Astro.props;
---

<fieldset class:list={["checkbox-group", { "list": list }]}>
    <legend>{legend}</legend>
    {options.map((option) => (
        <>
            <input 
                type="checkbox" 
                id={option.id} 
                name={option.name || option.id} 
                value={option.value} 
                placeholder=" " 
                required={option.required} 
                checked={option.checked}
                tabindex={tabindex}
                {...(option.target ? { "data-target": option.target } : {})}
            />
            <label for={option.id}>{option.label}</label>
        </>
    ))}
</fieldset>


