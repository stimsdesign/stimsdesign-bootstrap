---
/*************************************************************************
 * @forms/Password.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A password input field with built-in visibility toggling.
 * 
 * Usage:
 *  <Password id="login-pass" label="Your Password" required tabindex={2} />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/TextInput.css";

// Props
interface Props {
    /** The unique identifier for the password input. */
    id: string;
    /** The name attribute for the input element. Defaults to id. */
    name?: string;
    /** The label text displayed for the input. Default is "Password". */
    label?: string;
    /** Whether the field is required. Default is false. */
    required?: boolean;
    /** Tabindex offset for keyboard navigation. */
    tabindex?: number;
    [key: string]: any;
}

// Destructuring Props
const { id, name = id, label = "Password", required = false, tabindex, ...rest } = Astro.props;
---

<div class="input-group">
    <label for={id}>{label}</label>
    <div class="password-input-wrapper">
        <input 
            type="password" 
            id={id} 
            name={name} 
            placeholder=" " 
            required={required} 
            tabindex={tabindex}
            {...rest}
        />
        <button type="button" class="toggle-password" aria-label="Toggle password visibility" tabindex="-1">
            Show
        </button>
    </div>
</div>