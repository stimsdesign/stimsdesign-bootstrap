---
/*************************************************************************
 * @forms/PhoneInput.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A text input preconfigured for telephone numbers.
 * 
 * Usage:
 *  <PhoneInput id="contact-phone" required tabindex={2} />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/TextInput.css";

// Import → Elements
import TextInput from "./TextInput.astro";

// Props
interface Props {
    /** The unique identifier for the input element. */
    id: string;
    /** The name attribute for the input element. Defaults to id. */
    name?: string;
    /** The label text displayed for the input. Default is "Phone Number". */
    label?: string;
    /** Whether the field is required. Default is false. */
    required?: boolean;
    [key: string]: any;
}

// Destructuring Props
const { 
    id, 
    name = id,
    label = "Phone Number", 
    required = false, 
    ...rest 
} = Astro.props;
---

<TextInput 
    type="tel" 
    id={id} 
    name={name} 
    label={label} 
    required={required} 
    autocomplete="tel" 
    {...rest} 
/>
