---
/*************************************************************************
 * @forms/TextArea.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A multi-line text input field supporting float label layout.
 * 
 * Usage:
 *  <TextArea id="comments" label="Comments" rows={5} required />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/TextInput.css";

// Props
interface Props {
    /** The unique identifier for the textarea element. */
    id: string;
    /** The name attribute for the textarea element. Defaults to id. */
    name?: string;
    /** The label text displayed above or inside the field. */
    label?: string;
    /** The placeholder text. Default is a space (" ") to trigger floating labels. */
    placeholder?: string;
    /** Whether the field is required. Default is false. */
    required?: boolean;
    /** The number of visible text lines / height of the field. Default is 4. */
    rows?: number | string;
    [key: string]: any;
}

// Destructuring Props
const { 
    id, 
    name = id,
    label, 
    placeholder = " ", 
    required = false, 
    rows = 4,
    ...rest 
} = Astro.props;
---

<div class="input-group">
    {label && <label for={id}>{label}</label>}
    <textarea 
        id={id} 
        name={name} 
        placeholder={placeholder} 
        required={required}
        rows={rows}
        {...rest} 
    ></textarea>
</div>


