---
/*************************************************************************
 * @forms/EmailInput.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A text input preconfigured for email addresses with built-in validation.
 * 
 * Usage:
 *  <EmailInput id="contact-email" required tabindex={1} />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/inputs.css";

// Import → Elements
import TextInput from "./TextInput.astro";

// Props
interface Props {
    /** The unique identifier for the input element. */
    id: string;
    /** The name attribute for the input element. Defaults to id. */
    name?: string;
    /** The label text displayed for the input. Default is "Email Address". */
    label?: string;
    /** Whether the field is required. Default is false. */
    required?: boolean;
    [key: string]: any;
}

// Destructuring Props
const { 
    id, 
    name = id,
    label = "Email Address", 
    required = false, 
    ...rest 
} = Astro.props;
---

<TextInput 
    type="email" 
    id={id} 
    name={name} 
    label={label} 
    required={required} 
    autocomplete="email" 
    {...rest} 
/>
