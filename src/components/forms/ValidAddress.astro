---
/*************************************************************************
 * @forms/ValidAddress.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A grouped address component (Street, Apt, City, State, Zip) integrated 
 *  with address suggestion APIs (photon/google/mapbox) and autocomplete.
 * 
 * Usage:
 *  <ValidAddress id="billing" provider="photon" formRow={true} verify={false} required />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/valid-address.css";

// Import → Elements
import AddressInput from "./AddressInput.astro";
import Address2Input from "./Address2Input.astro";
import CityInput from "./CityInput.astro";
import StateInput from "./StateInput.astro";
import ZipInput from "./ZipInput.astro";

// Props
interface Props {
    /** The base prefix ID for all child input fields. Default is "address". */
    id?: string;
    /** The address suggestion provider API. Default is "photon". */
    provider?: "photon" | "google" | "mapbox" | "none";
    /** If true, the address fields are marked as required. Default is false. */
    required?: boolean;
    /** If true, groups City/State/Zip horizontally using the .form-row class. Default is true. */
    formRow?: boolean;
    /** If true, enables strict validation constraints. Default is false. */
    verify?: boolean;
    /** Tabindex offset for keyboard navigation. */
    tabindex?: number;
}

// Destructuring Props
const { 
    id = "address", 
    provider = "photon", 
    required = false,
    formRow = true,
    verify = false,
    tabindex
} = Astro.props;

const prefix = id;

const Wrapper = formRow ? 'div' : Fragment;
const wrapperProps = formRow ? { class: "form-row" } : {};
---

<div class="valid-address-group" data-address-provider={provider} data-id-prefix={prefix} data-verify={verify}>
    <div class="street-address-container">
        <AddressInput id={`${prefix}-street`} required={required} tabindex={tabindex} />
        <div class="address-suggestions scroll-thin hidden" id={`${prefix}-suggestions`}></div>
    </div>
    
    <Address2Input id={`${prefix}-apt`} tabindex={tabindex} />
    
    <Wrapper {...wrapperProps}>
        <CityInput id={`${prefix}-city`} required={required} tabindex={tabindex} />
        <StateInput id={`${prefix}-state`} required={required} tabindex={tabindex} />
        <ZipInput id={`${prefix}-zip`} required={required} tabindex={tabindex} />
    </Wrapper>

    <input type="hidden" id={`${prefix}-verified`} name={`${prefix}-verified`} value="false" class="address-verified-flag" />
</div>


