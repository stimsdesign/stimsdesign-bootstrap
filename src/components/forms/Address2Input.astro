---
/*************************************************************************
 * @forms/Address2Input.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A text input specifically tailored for secondary address details 
 *  (e.g., apartment, suite, building, or unit number).
 * 
 * Usage:
 *  <Address2Input id="shipping-apt" tabindex={2} />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/TextInput.css";

// Import → Elements
import TextInput from "./TextInput.astro";

// Props
interface Props {
    /** The unique identifier for the input element. Default is "address2". */
    id?: string;
    /** The label text for the input. Default is "Apt, Suite, etc. (Optional)". */
    label?: string;
    [key: string]: any;
}

// Destructuring Props
const { id = "address2", label = "Apt, Suite, etc. (Optional)", ...rest } = Astro.props;
---
<TextInput id={id} label={label} autocomplete="address-line2" {...rest} />

