---
/*************************************************************************
 * @forms/ZipInput.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A text input specifically configured for 5-digit zip or postal codes.
 * 
 * Usage:
 *  <ZipInput id="shipping-zip" required tabindex={5} />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/TextInput.css";

// Import → Elements
import TextInput from "./TextInput.astro";

// Props
interface Props {
    /** The unique identifier for the input element. Default is "zip". */
    id?: string;
    /** The label text for the input. Default is "Zip / Postal Code". */
    label?: string;
    [key: string]: any;
}

// Destructuring Props
const { id = "zip", label = "Zip / Postal Code", ...rest } = Astro.props;
---
<TextInput 
    type="text" 
    id={id} 
    label={label} 
    autocomplete="postal-code" 
    inputmode="numeric" 
    pattern="[0-9]{5}" 
    maxlength={5} 
    {...rest} 
/>

