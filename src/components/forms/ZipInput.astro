---
// Import → CSS
import "@form-styles/inputs.css";

// Import → Elements
import TextInput from "./TextInput.astro";

const { id = "zip", label = "Zip / Postal Code", ...rest } = Astro.props;
---
<TextInput 
    type="text" 
    id={id} 
    label={label} 
    autocomplete="postal-code" 
    inputmode="numeric" 
    pattern="[0-9]{5}" 
    maxlength={5} 
    {...rest} 
/>
