---
/*************************************************************************
 * @forms/AddressInput.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A text input specifically tailored for the main street address line 
 *  (e.g., house number, street name).
 * 
 * Usage:
 *  <AddressInput id="shipping-address" required tabindex={1} />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/TextInput.css";

// Import → Elements
import TextInput from "./TextInput.astro";

// Props
interface Props {
    /** The unique identifier for the input element. Default is "address". */
    id?: string;
    /** The label text for the input. Default is "Street Address". */
    label?: string;
    [key: string]: any;
}

// Destructuring Props
const { id = "address", label = "Street Address", ...rest } = Astro.props;
---
<TextInput id={id} label={label} autocomplete="address-line1" {...rest} />

