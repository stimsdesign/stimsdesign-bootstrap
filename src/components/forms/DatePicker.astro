---
/*************************************************************************
 * @forms/DatePicker.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A text input integrated with a custom popup date-picker calendar widget.
 * 
 * Usage:
 *  <DatePicker 
 *      id="booking-date" 
 *      label="Choose Date" 
 *      days="Monday, Tuesday, Wednesday, Thursday" 
 *      endRange={90} 
 *      excludedDates="05/07/26, 05/05/26" 
 *      hideDays 
 *      disableHistory 
 *      tabindex={5} 
 *  />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/DatePicker.css";

// Import → Elements
import Icon from "../elements/SVGicon.astro";

// Props
interface Props {
    /** The unique identifier for the date input. */
    id: string;
    /** The label text displayed above the date picker input. Default is "Preferred Date". */
    label?: string;
    /** Comma-separated list of active days of the week (e.g. "mon,tue,wed"). Default is all days. */
    days?: string;
    /** If true, weekends are enabled for selection. Default is true. */
    weekends?: boolean;
    /** Offset in days for the first selectable date. Default is 0. */
    startRange?: number;
    /** Restricts the calendar past this forward offset in days. */
    endRange?: number;
    /** Comma-separated MM/DD/YY dates to disable. */
    excludedDates?: string;
    /** If true, condenses the calendar grid dynamically by skipping disabled days. Default is false. */
    hideDays?: boolean;
    /** If true, prevents backwards historical date selection. Default is false. */
    disableHistory?: boolean;
    /** Whether selecting a date is required. Default is false. */
    required?: boolean;
    /** Tabindex offset for keyboard navigation. */
    tabindex?: number;
}

// Destructuring Props
const { 
    id, 
    label = "Preferred Date", 
    days = "sun,mon,tue,wed,thu,fri,sat", 
    weekends = true, 
    startRange = 0, 
    endRange,
    excludedDates = "",
    hideDays = false,
    disableHistory = false,
    required = false,
    tabindex
} = Astro.props;

const months = [
    "January", "February", "March", "April", "May", "June",
    "July", "August", "September", "October", "November", "December"
];
---

<div 
    class="input-group" 
    data-days={days} 
    data-weekends={String(weekends)} 
    data-start-range={startRange} 
    data-end-range={endRange}
    data-excluded-dates={excludedDates}
    data-hide-days={String(hideDays)}
    data-disable-history={String(disableHistory)}
>
    <label for={id}>{label}</label>
    <input 
        type="text" 
        id={id} 
        name={id} 
        class="date-input" 
        inputmode="none" 
        autocomplete="off" 
        placeholder=" " 
        required={required} 
        aria-required={required ? "true" : "false"} 
        tabindex={tabindex}
    />
    <div class="datepicker__wrapper hidden" hidden="true">
        <div class="datepicker">
            <div class="datepicker__header">
                <button type="button" class="prev-month" aria-label="Previous Month"><Icon name="arrow-left" /></button>
                <div class="month-year">
                    <select class="month-input" aria-label="Select Month">
                        {months.map((month) => (
                            <option value={month}>{month}</option>
                        ))}
                    </select>
                    <input type="number" class="year-input" min="1900" max="2100" aria-label="Year" />
                </div>
                <button type="button" class="next-month" aria-label="Next Month"><Icon name="arrow-right" /></button>
            </div>
            <div class="days">
                <span>Sun</span>
                <span>Mon</span>
                <span>Tue</span>
                <span>Wed</span>
                <span>Thu</span>
                <span>Fri</span>
                <span>Sat</span>
            </div>
            <div class="dates"></div>
        </div>
    </div>
</div>