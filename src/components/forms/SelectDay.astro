---
/*************************************************************************
 * @forms/SelectDay.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A custom day selection calendar widget that allows selection of a day 
 *  in a calendar/week view format.
 * 
 * Usage:
 *  <SelectDay 
 *      id="appointment-day" 
 *      label="Choose Day" 
 *      days="Monday, Tuesday, Wednesday, Thursday" 
 *      hideDays 
 *      weekView 
 *      required 
 *  />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/select-day.css";

// Import → Elements
import Icon from "../elements/SVGicon.astro";

// Props
interface Props {
    /** The unique identifier for the hidden input element. */
    id: string;
    /** The label text displayed above the calendar widget. Default is "Preferred Day". */
    label?: string;
    /** Comma-separated list of active days of the week (e.g. "mon,tue,wed"). Default is all days. */
    days?: string;
    /** If true, weekends are enabled for selection. Default is true. */
    weekends?: boolean;
    /** Offset in days for the first selectable date. Default is 0. */
    startRange?: number;
    /** Restricts the calendar past this forward offset in days. */
    endRange?: number;
    /** Comma-separated MM/DD/YY dates to disable. */
    excludedDates?: string;
    /** If true, condenses the calendar grid dynamically by skipping disabled days. Default is false. */
    hideDays?: boolean;
    /** If true, only displays one selectable week at a time. Default is false. */
    weekView?: boolean;
    /** If true, prevents backwards historical date selection. Default is false. */
    disableHistory?: boolean;
    /** Whether selecting a day is required. Default is false. */
    required?: boolean;
    /** Tabindex offset for keyboard navigation. */
    tabindex?: number;
}

// Destructuring Props
const { 
    id, 
    label = "Preferred Day", 
    days = "sun,mon,tue,wed,thu,fri,sat", 
    weekends = true, 
    startRange = 0, 
    endRange,
    excludedDates = "",
    hideDays = false,
    weekView = false,
    disableHistory = false,
    required = false
} = Astro.props;
---

<div 
    class="custom-group" 
    data-days={days} 
    data-weekends={String(weekends)} 
    data-start-range={startRange} 
    data-end-range={endRange}
    data-excluded-dates={excludedDates}
    data-hide-days={String(hideDays)}
    data-week-view={String(weekView)}
    data-disable-history={String(disableHistory)}
>    
    <label>{label}</label>
    <input type="hidden" id={id} name={id} required={required} class="date-input" />
    <div class="select-day">
        <div class="select-day__header">
            <span class="month-input" aria-label="Month"></span>
            <span class="year-input" aria-label="Year"></span>
        </div>
        <div class="select-day__calendar">
            <button type="button" class="prev-month" aria-label="Previous Month" tabindex="-1"><Icon name="arrow-left" /></button>
            <div>
                <div class="days">
                    <span>Sun</span>
                    <span>Mon</span>
                    <span>Tue</span>
                    <span>Wed</span>
                    <span>Thu</span>
                    <span>Fri</span>
                    <span>Sat</span>
                </div>
                <div class="dates"></div>
            </div>
            <button type="button" class="next-month" aria-label="Next Month" tabindex="-1"><Icon name="arrow-right" /></button>
        </div>
    </div>
</div>