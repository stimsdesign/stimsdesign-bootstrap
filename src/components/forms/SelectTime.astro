---
/*************************************************************************
 * @forms/SelectTime.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A custom dropdown selection list filled with generated time slots 
 *  based on configured boundaries and minute increments.
 * 
 * Usage:
 *  <SelectTime 
 *      id="appt-time" 
 *      label="Time Slot" 
 *      startTime="08:00" 
 *      endTime="18:00" 
 *      increment={45} 
 *      required 
 *  />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/selectboxes.css";

// Props
interface Props {
    /** The unique identifier for the select element. */
    id: string;
    /** The name attribute for the select element. Defaults to id. */
    name?: string;
    /** The label text displayed for the selection dropdown. Default is "Preferred Time". */
    label?: string;
    /** Whether selecting a time is required. Default is false. */
    required?: boolean;
    /** Text for the default empty disabled option. Default is "Select a Time". */
    defaultValue?: string;
    /** If true, visually hides the label but keeps it available for screen readers. Default is false. */
    hideLabel?: boolean;
    /** Time format display (12-hour or 24-hour). Default is 12. */
    format?: 12 | 24;
    /** The 24h format "HH:mm" start boundary. Default is "09:00". */
    startTime?: string;
    /** The 24h format "HH:mm" end boundary. Default is "17:00". */
    endTime?: string;
    /** The number of minutes between generated choices. Default is 30. */
    increment?: number;
    [key: string]: any;
}

// Destructuring Props
const { 
    id, 
    name = id,
    label = "Preferred Time", 
    required = false, 
    defaultValue = "Select a Time",
    hideLabel = false,
    format = 12,
    startTime = "09:00",
    endTime = "17:00",
    increment = 30,
    ...rest 
} = Astro.props;

// Protection: Ensure increment is a whole divisor of 60, otherwise fallback to 30
const step = (60 % Number(increment) === 0) ? Number(increment) : 30;

// Generate time options
const options = [];
const startArr = startTime.split(':').map(Number);
const endArr = endTime.split(':').map(Number);

let current = new Date();
current.setHours(startArr[0], startArr[1], 0, 0);

const end = new Date();
end.setHours(endArr[0], endArr[1], 0, 0);

while (current <= end) {
    const hours = current.getHours();
    const minutes = current.getMinutes();
    
    // Value is always 24h format
    const value = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}`;
    
    // Label follows format prop
    let displayLabel: string;
    if (format === 24) {
        displayLabel = value;
    } else {
        const period = hours >= 12 ? 'PM' : 'AM';
        const hours12 = hours % 12 || 12;
        displayLabel = `${hours12}:${minutes.toString().padStart(2, '0')} ${period}`;
    }
    
    options.push({ label: displayLabel, value });
    current.setMinutes(current.getMinutes() + step);
}
---

<div class="select-group">
    {label && <label for={id} class={hideLabel ? "hidden" : ""}>{label}</label>}
    <select id={id} name={name} required={required} {...rest}>
        <option value="">{defaultValue}</option>
        {options.map((option) => (
            <option value={option.value}>{option.label}</option>
        ))}
    </select>
</div>