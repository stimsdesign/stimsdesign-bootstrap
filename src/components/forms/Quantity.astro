---
/*************************************************************************
 * @forms/Quantity.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A custom numerical counter input with decrement/increment plus and minus 
 *  buttons.
 * 
 * Usage:
 *  <Quantity id="ticket-count" label="Tickets" min={1} max={10} step={1} value={1} />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/Quantity.css";

// Props
interface Props {
    /** The unique identifier for the input element. */
    id: string;
    /** The name attribute for the input element. Defaults to id. */
    name?: string;
    /** The label text displayed for the input. */
    label?: string;
    /** The minimum selectable numerical value. Default is 0. */
    min?: number | string;
    /** The maximum selectable numerical value. */
    max?: number | string;
    /** The legal numerical interval between choices. Default is 1. */
    step?: number | string;
    /** The default preset value. Defaults to min. */
    value?: number | string;
    /** Whether the field is required. Default is false. */
    required?: boolean;
    /** Additional CSS classes. */
    class?: string;
    /** Tabindex offset for keyboard navigation. */
    tabindex?: number;
    [key: string]: any;
}

// Destructuring Props
const { 
    id, 
    name = id,
    label, 
    min = 0,
    max,
    step = 1,
    value = min,
    required = false, 
    class: className = "",
    tabindex,
    ...rest 
} = Astro.props;

// Calculate width based on max value length
const width = max ? String(max).length + 0.5 : 4;
---

<div class={`quantity-group ${className}`}>
    {label && <label for={id}>{label}</label>}
    <div class="quantity-input">
        <button type="button" class="minus" aria-label="Decrease quantity" tabindex="-1">−</button>
        <input 
            type="number" 
            id={id} 
            name={name} 
            min={min} 
            max={max} 
            step={step} 
            value={value} 
            placeholder=" " 
            required={required} 
            style={`width: ${width}em`}
            tabindex={tabindex}
            {...rest} 
        />
        <button type="button" class="plus" aria-label="Increase quantity" tabindex="-1">+</button>
    </div>
</div>