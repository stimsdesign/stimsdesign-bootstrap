---
/*************************************************************************
 * @forms/LastNameInput.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A text input preconfigured for a user's last name.
 * 
 * Usage:
 *  <LastNameInput id="last-name" required tabindex={2} />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/inputs.css";

// Import → Elements
import TextInput from "./TextInput.astro";

// Props
interface Props {
    /** The unique identifier for the input element. */
    id: string;
    /** The name attribute for the input element. Defaults to id. */
    name?: string;
    /** The label text displayed for the input. Default is "Last Name". */
    label?: string;
    /** Whether the field is required. Default is false. */
    required?: boolean;
    [key: string]: any;
}

// Destructuring Props
const { 
    id, 
    name = id,
    label = "Last Name", 
    required = false, 
    ...rest 
} = Astro.props;
---

<TextInput 
    id={id} 
    name={name} 
    label={label} 
    required={required} 
    autocomplete="family-name" 
    {...rest} 
/>
