---
/*************************************************************************
 * @forms/CreatePassword.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A pair of password inputs (create & confirm) with built-in validation 
 *  rules/strength checklist and show/hide toggles.
 * 
 * Usage:
 *  <CreatePassword id="signup-password" form-row={true} tabindex={4} />
 * 
 *************************************************************************/

// Import → CSS
import "@form-styles/CreatePassword.css";

// Props
interface Props {
    /** The base prefix ID for the password fields. Default is "password". */
    id?: string;
    /** The label for the first password input. Default is "Create Password". */
    createLabel?: string;
    /** The label for the confirm password input. Default is "Confirm Password". */
    confirmLabel?: string;
    /** Whether the confirm password field is required. Default is true. */
    required?: boolean;
    /** If true, groups both input fields side-by-side in a single row. Default is false. */
    "form-row"?: boolean | string;
    /** Tabindex offset for keyboard navigation. */
    tabindex?: number;
}

// Destructuring Props
const { 
    id = "password", 
    createLabel = "Create Password", 
    confirmLabel = "Confirm Password", 
    required = true,
    "form-row": formRowParam = false,
    tabindex
} = Astro.props;

const formRow = formRowParam === "true" || formRowParam === true;

const Tag = formRow ? 'div' : Fragment;
const props = formRow ? { class: "form-row" } : {};
---

<Tag {...props}>
    <div class="input-group">
        <label for={`${id}-create`}>{createLabel}</label>
        <div class="password-input-wrapper">
            <input 
                type="password" 
                id={`${id}-create`} 
                name={`${id}`} 
                placeholder=" " 
                required 
                tabindex={tabindex}
            />
            <button type="button" class="toggle-password" aria-label="Toggle password visibility" tabindex="-1">
                Show
            </button>
        </div>
    </div>

    <div class="input-group">
        <label for={`${id}-confirm`}>{confirmLabel}</label>
        <div class="password-input-wrapper">
            <input 
                type="password" 
                id={`${id}-confirm`} 
                name={`${id}-confirm`} 
                placeholder=" " 
                required={required} 
                tabindex={tabindex}
            />
            <button type="button" class="toggle-password" aria-label="Toggle password visibility" tabindex="-1">
                Show
            </button>
        </div>
    </div>

    <div class="password-requirements small">
        Passwords must be: 
        <span class="req-characters">8 characters minimum</span>, 
        <span class="req-uppercase">include an uppercase character</span>, 
        <span class="req-number">include a number</span>, and 
        <span class="req-special">include a special character</span>.
    </div>


</Tag>

