---
/**
 * @prop {string} createLabel - Label for the first password field
 * @prop {string} confirmLabel - Label for the confirm password field
 * @prop {boolean|string} form-row - If true, renders both fields side-by-side
 */

interface Props {
    id?: string;
    createLabel?: string;
    confirmLabel?: string;
    required?: boolean;
    "form-row"?: boolean | string;
    tabindex?: number;
}

const { 
    id = "password", 
    createLabel = "Create Password", 
    confirmLabel = "Confirm Password", 
    required = true,
    "form-row": formRowParam = false,
    tabindex
} = Astro.props;

const formRow = formRowParam === "true" || formRowParam === true;

const Tag = formRow ? 'div' : Fragment;
const props = formRow ? { class: "form-row" } : {};
---

<Tag {...props}>
    <div class="input-group">
        <label for={`${id}-create`}>{createLabel}</label>
        <div class="password-input-wrapper">
            <input 
                type="password" 
                id={`${id}-create`} 
                name={`${id}`} 
                placeholder=" " 
                required 
                tabindex={tabindex}
            />
            <button type="button" class="toggle-password" aria-label="Toggle password visibility" tabindex="-1">
                Show
            </button>
        </div>
    </div>

    <div class="input-group">
        <label for={`${id}-confirm`}>{confirmLabel}</label>
        <div class="password-input-wrapper">
            <input 
                type="password" 
                id={`${id}-confirm`} 
                name={`${id}-confirm`} 
                placeholder=" " 
                required={required} 
                tabindex={tabindex}
            />
            <button type="button" class="toggle-password" aria-label="Toggle password visibility" tabindex="-1">
                Show
            </button>
        </div>
    </div>

    <div class="password-requirements small">
        Passwords must be: 
        <span class="req-characters">8 characters minimum</span>, 
        <span class="req-uppercase">include an uppercase character</span>, 
        <span class="req-number">include a number</span>, and 
        <span class="req-special">include a special character</span>.
    </div>


</Tag>

