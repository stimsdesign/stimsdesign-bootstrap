---
/*************************************************************************
 * @forms/FileInput.astro
 * -----------------------------------------------------------------------
 * 
 * Description:
 *  A file upload input supporting custom validation of file size and 
 *  MIME types, with error message indicators.
 * 
 * Usage:
 *  <FileInput id="resume" label="Upload Resume" accept=".pdf,.doc" maxSize={5} required />
 * 
 *************************************************************************/

// Import → Site Config
import { Site } from "@site.config";

// Import → CSS
import "@form-styles/file-input.css";

// Props
interface Props {
    /** The unique identifier for the file input. */
    id: string;
    /** The name attribute for the input element. Defaults to id. */
    name?: string;
    /** The label text displayed for the input. Default is "Upload File". */
    label?: string;
    /** Standard HTML accept attribute (e.g. ".jpg,.png"). Defaults to allowedTypes. */
    accept?: string;
    /** Maximum allowed file size in MB. Defaults to Site.DefaultFileSize. */
    maxSize?: number;
    /** Comma-separated MIME types allowed. Defaults to Site.DefaultFileTypes. */
    allowedTypes?: string;
    /** Whether the file selection is required. Default is false. */
    required?: boolean;
    /** Custom requirements text, overriding the auto-generator. */
    requirements?: string;
    [key: string]: any;
}

// Destructuring Props
const { 
    id, 
    name = id,
    label = "Upload File", 
    accept, 
    maxSize = Site.DefaultFileSize, 
    allowedTypes = Site.DefaultFileTypes,
    required = false,
    requirements,
    ...rest 
} = Astro.props;

// Human-readable MIME type mapping
const mimeToExt: Record<string, string> = {
    'application/pdf': 'PDF',
    'image/jpeg': 'JPG',
    'image/png': 'PNG',
    'image/gif': 'GIF',
    'text/plain': 'TXT',
    'text/csv': 'CSV',
    'application/msword': 'DOC',
    'application/vnd.openxmlformats-officedocument.wordprocessingml.document': 'DOCX',
    'application/vnd.ms-excel': 'XLS',
    'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet': 'XLSX',
    'application/zip': 'ZIP'
};

const getHumanReadableTypes = (types: string) => {
    return types.split(',')
        .map(t => t.trim())
        .map(t => mimeToExt[t] || t.split('/')[1]?.toUpperCase() || t)
        .filter((value, index, self) => self.indexOf(value) === index) // Unique extensions
        .join(', ');
};

const autoRequirements = `Files: ${getHumanReadableTypes(allowedTypes)} | Max File Size: ${maxSize}MB`;
const displayRequirements = requirements || autoRequirements;
---

<div class="file-group">
    {label && <label for={id}>{label}</label>}
    <input 
        type="file" 
        id={id} 
        name={name} 
        accept={accept || allowedTypes}
        data-max-size={maxSize}
        data-allowed-types={allowedTypes}
        required={required}
        {...rest}
    />
    <div class="file-notation">
        <span class="file-requirements">{displayRequirements}</span>
        <span class="file-type-warning">File Type not Supported</span>
        <span class="file-size-warning">File Size too Large</span>
    </div>
</div>


