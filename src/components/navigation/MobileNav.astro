---
/* MobileNav.astro */
const links = [
    { name: "Home", href: "/" },
    { name: "Services", href: "/services.html" },
    { name: "Pricing", href: "/services.html#pricing" },
    { name: "Contact", href: "/contact.html" },
    { name: 'Get "Quote"', href: "/estimate.html" },
];

import PortalEntryIcon from "../../icons/portal-entry.svg";
---

<div class="mobile-nav-container">
    <input type="checkbox" id="mobile-toggle" class="mobile-toggle" hidden aria-hidden="true" />

    <!-- Hamburger Button -->
    <label for="mobile-toggle" id="mobile-hamburger" class="hamburger-btn" aria-label="Open Menu">
        <span class="hamburger-box">
            <span class="hamburger-inner"></span>
        </span>
    </label>

    <!-- Slide-out Drawer -->
    <div id="mobile-menu-drawer" class="menu-drawer">
        <div class="drawer-header">
            <label for="mobile-toggle" id="mobile-menu-close" class="close-btn" aria-label="Close Menu">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </label>
        </div>
        <nav class="drawer-nav">
            <ul>
                {
                    links.map((link) => (
                        <li><a href={link.href}>{link.name}</a></li>
                    ))
                }
            </ul>
        </nav>
        <div class="drawer-footer">
            <a href="/portal" class="portal-link">Client Portal<PortalEntryIcon /></a>
            <p>&copy; {new Date().getFullYear()} STIMS Design LLC</p>
        </div>
    </div>

    <!-- Overlay -->
    <label for="mobile-toggle" id="mobile-menu-overlay" class="menu-overlay"></label>
</div>

<style is:global>
    /* variables context from BaseLayout.astro layout is inherited */

    .mobile-nav-container {
        pointer-events: none; /* Let clicks pass through unless on specific buttons */
    }

    .hamburger-btn {
        pointer-events: auto;
        position: fixed;
        top: 1.25rem;
        left: 1.25rem;
        z-index: 2000;
        width: 50px;
        height: 50px;
        background-color: color-mix(
            in srgb,
            var(--color-secondary-dark),
            transparent 80%
        );
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
            transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
            background-color 0.3s ease,
            opacity 0.5s ease,
            visibility 0.5s ease;
        opacity: 0;
        visibility: hidden;
    }

    .hamburger-btn.is-visible {
        opacity: 1;
        visibility: visible;
    }

    @media (max-width: 768px) {
        .hamburger-btn {
            opacity: 1;
            visibility: visible;
            top: 0.5rem;
            left: 0.5rem;
        }
    }

    .hamburger-btn:hover {
        background-color: color-mix(
            in srgb,
            var(--color-secondary),
            transparent 80%
        );
    }

    .hamburger-btn:active {
        transform: scale(0.95);
    }

    /* Hamburger Icon CSS */
    .hamburger-box {
        width: 24px;
        height: 14px;
        display: block;
        position: relative;
    }

    .hamburger-inner,
    .hamburger-inner::before,
    .hamburger-inner::after {
        width: 100%;
        height: 2px;
        background-color: var(--color-accent);
        position: absolute;
        left: 0;
        transition: transform 0.15s ease;
        border-radius: 4px;
    }

    .hamburger-inner {
        top: 50%;
        transform: translateY(-50%);
    }
    .hamburger-inner::before {
        content: "";
        top: -6px;
    }
    .hamburger-inner::after {
        content: "";
        top: 6px;
    }

    /* Menu Drawer Logic */
    .mobile-toggle:checked ~ .menu-drawer {
        transform: translateX(0);
        box-shadow: 10px 0 30px rgba(0, 0, 0, 0.5);
    }

    .mobile-toggle:checked ~ .menu-overlay {
        pointer-events: auto;
        opacity: 1;
        visibility: visible;
    }

    .mobile-toggle:checked ~ .menu-drawer .drawer-nav li {
        opacity: 1;
        transform: translateX(0);
    }

    .menu-drawer {
        pointer-events: auto;
        position: fixed;
        top: 0;
        left: 0;
        width: 80vw;
        height: 100dvh;
        background-color: var(--color-primary-darker);
        border-right: 1px solid var(--color-accent-dark);
        border-top: 1px solid var(--color-accent-dark);
        border-bottom: 1px solid var(--color-accent-dark);
        border-radius: 0 20px 20px 0;
        z-index: 2100;
        display: flex;
        flex-direction: column;
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateX(-100%);
        container-type: inline-size;
        overflow-x: hidden;
    }

    @media (min-width: 769px) {
        .menu-drawer {
            width: 45vw; /* Increased width for tablet to allow space for large labels */
        }
    }

    @media (min-width: 1200px) {
        .menu-drawer {
            width: 25vw; /* Return to sleek width for large screens */
            max-width: 400px;
        }
    }

    .drawer-header {
        padding: 1.5rem;
        display: flex;
        justify-content: flex-end;
    }

    .close-btn {
        background: none;
        border: none;
        color: var(--color-accent);
        cursor: pointer;
        padding: 0.5rem;
        transition: transform 0.3s ease;
    }

    .close-btn:hover {
        transform: rotate(90deg);
    }

    .drawer-nav {
        flex: 1;
        padding: 0 1.5rem;
    }

    .drawer-nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .drawer-nav li {
        margin-bottom: 1rem;
        opacity: 0;
        transform: translateX(-20px);
        transition:
            opacity 0.3s ease,
            transform 0.3s ease;
    }

    /* Stagger the links */
    .drawer-nav li:nth-child(1) {
        transition-delay: 0.1s;
    }
    .drawer-nav li:nth-child(2) {
        transition-delay: 0.15s;
    }
    .drawer-nav li:nth-child(3) {
        transition-delay: 0.2s;
    }
    .drawer-nav li:nth-child(4) {
        transition-delay: 0.25s;
    }
    .drawer-nav li:nth-child(5) {
        transition-delay: 0.3s;
    }
    .drawer-nav li:nth-child(6) {
        transition-delay: 0.35s;
    }

    .drawer-nav a {
        font-family: var(--family-heading);
        white-space: nowrap;
        font-size: var(--size-2xl);
        font-weight: var(--weight-bold);
        color: var(--color-foreground);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: block;
        padding: 0.5rem 0;
        transition:
            color 0.3s ease,
            padding-left 0.3s ease;
    }

    .drawer-nav a:hover {
        color: var(--color-accent);
        padding-left: 0.5rem;
        text-decoration: none;
    }

    .portal-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--family-heading);
        font-size: var(--size-xl);
        font-weight: var(--weight-bold);
        color: var(--color-accent);
        text-decoration: none;
        text-transform: uppercase;
        padding: 1rem 0;
        margin-bottom: 1rem;
        transition: color 0.3s ease;
    }

    .portal-link:hover {
        color: white;
    }

    .portal-link svg {
        width: 1.5rem;
        height: 1.5rem;
    }

    .drawer-footer {
        padding: 2rem 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .drawer-footer p {
        font-size: var(--size-xs);
        color: var(--color-foreground-dark);
        margin: 0;
    }

    /* Overlay */
    .menu-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        z-index: 2050;
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.4s ease,
            visibility 0.4s ease;
    }
</style>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const toggle = document.getElementById("mobile-toggle");
        const hamburger = document.getElementById("mobile-hamburger");
        const drawer = document.getElementById("mobile-menu-drawer");

        // Body scroll lock
        toggle?.addEventListener("change", () => {
            if (toggle.checked) {
                document.body.style.overflow = "hidden";
            } else {
                document.body.style.overflow = "";
            }
        });

        // Close on swipeLeft (custom event)
        drawer?.addEventListener("swipeLeft", () => {
            if (toggle) toggle.checked = false;
            document.body.style.overflow = "";
        });

        // Interaction Observer for Desktop Sticky Hamburger
        const mainNav =
            document.getElementById("main-nav-observer") ||
            document.getElementById("portal-nav-observer");
        if (mainNav) {
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (!entry.isIntersecting) {
                            hamburger?.classList.add("is-visible");
                            mainNav.classList.add("is-hidden");
                        } else {
                            hamburger?.classList.remove("is-visible");
                            mainNav.classList.remove("is-hidden");
                        }
                    });
                },
                {
                    threshold: 0,
                    rootMargin: "-20px 0px 0px 0px",
                },
            );

            observer.observe(mainNav);
        }
    });
</script>
