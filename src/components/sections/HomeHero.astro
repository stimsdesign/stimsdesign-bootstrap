6.19-5.82h-.15c-3.98,0-6.19,2.06-6.19,5.82s2.21,5.82,6.26,5.82,6.26-2.06,6.26-5.82ZM246.76,27.9c3.1,0,4.64-1.92,4.64-4.57s-1.55-4.57-4.72-4.57-4.72,1.92-4.72,4.57,1.55,4.57,4.64,4.57h.15Z" fill="%23dbd3d3"/><path d="M269.2,31.62c0-2.49,2.04-4.53,4.53-4.53s4.53,2.04,4.53,4.53-2.04,4.53-4.53,4.53-4.53-2.04-4.53-4.53Z" fill="%23dbd3d3"/><path d="M284.07,44.39h11.35c.59,2.87,2.65,4.94,5.9,4.94,3.83,0,6.04-2.58,6.04-7.22,0-3.91-2.21-6.49-6.04-6.49-2.73,0-4.57,1.4-5.53,3.54l-9.88-3.02,3.39-25.65h25.65v9.95h-17.1l-1.33,8.84c1.77-2.14,4.05-3.1,7.37-3.1,7.74,0,14.67,6.04,14.67,15.92,0,10.61-7.08,17.54-17.25,17.54-9.58,0-16.58-6.34-17.25-15.26Z" fill="%23dbd3d3"/><path d="M319.57,49.1l15.26-15.55c2.8-2.8,4.72-5.53,4.72-8.25,0-3.17-1.33-5.45-4.42-5.45s-4.42,2.21-4.42,5.53v1.03h-11.05v-.66c0-9.88,5.9-16.21,15.55-16.21s15.55,6.71,15.55,15.85c0,6.12-2.88,9.95-7.59,14.59l-8.99,8.77h15.99v9.95h-30.59v-9.58Z" fill="%23dbd3d3"/><path d="M353.72,42.32v-15.48c0-10.47,7.08-17.32,17.25-17.32s17.25,6.85,17.25,17.32v15.48c0,10.47-7.08,17.32-17.25,17.32s-17.25-6.85-17.25-17.32ZM377.16,42.32v-15.48c0-4.42-2.21-7-6.19-7s-6.19,2.58-6.19,7v15.48c0,4.42,2.21,7,6.19,7s6.19-2.58,6.19-7Z" fill="%23dbd3d3"/><path d="M409.64,49.25h-19.9v-9.58l19.9-29.19h11.05v28.82h4.13v9.95h-4.13v9.43h-11.05v-9.43ZM410.01,39.3v-13.78l-8.84,13.78h8.84Z" fill="%23dbd3d3"/></svg>');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: right center;
        }
        .phone-link span {
            display: none;
        }
    }

    @media (min-width: 769px) {
        #hero-section {
            border-top: solid 1px var(--color-accent);
            border-left: solid 1px var(--color-accent);
            border-right: solid 1px var(--color-accent);
            border-radius: 15px 15px 0 0;
            margin: 1rem auto 0;
        }
    }

    #hero-wrapper {
        position: relative;
        background-image: url("/images/homehero-bg.svg");
        background-repeat: no-repeat;
        background-size: cover;
        background-color: var(--color-primary-darker);
    }

    #hero {
        min-height: 80dvh;
        width: clamp(94%, 100% - 10cqi, 1440px);
        margin: 0 auto;
        padding: calc(5.5rem + 1cqi) 0 1cqi;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        gap: 3cqi;
    }

    #hero h1 {
        font-size: var(--size-2xl);
        line-height: 0.95em;
        margin-bottom: 1rem;
        text-wrap: wrap; /* Overriding global 'balance' to allow wider lines */
    }

    #hero p {
        font-size: var(--size-lg);
        line-height: 1.25em;
        color: var(--color-foreground);
    }

    #hero .hero-image {
        width: 100%;
        max-width: 45%;
        max-height: 40cqi;
        aspect-ratio: 16 / 9;
        object-fit: contain;
        transform: translateY(3cqi);
    }

    #hero .hero-image img {
        width: 100%;
        height: auto;
        object-fit: contain;
    }

    @container hero (max-width: 850px) {
        #hero {
            flex-direction: column;
            text-align: center;
            justify-content: center;
            padding-bottom: 2cqi;
        }
        #hero .hero-image {
            display: flex;
            justify-content: center;
            width: 100%;
            max-width: 85%;
            margin-top: 2cqi;
        }
        #hero #hero-text {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        #hero #hero-text .buttons {
            justify-content: center;
        }
    }

    @media (max-width: 768px) {
        #hero {
            padding-top: 6rem !important; /* Reduced clearance for Hamburger menu */
        }
    }

    @media (orientation: portrait) {
        #hero {
            flex-direction: column;
            text-align: center;
            justify-content: center;
            padding-top: calc(4.86cqi + 2cqi);
        }
        #hero .hero-image {
            display: flex;
            justify-content: center;
            width: 100%;
            max-width: 100%; /* More horizontal space */
            margin-top: 4cqi;
        }
        #hero #hero-text {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 2cqi;
        }
        #hero #hero-text .buttons {
            flex-direction: column; /* Stacked for more space */
            width: 100%;
            padding: 0 5cqi;
            gap: 1.25rem;
        }
        #hero #hero-text .buttons :global(.button) {
            width: 100%;
            padding: 1.25rem 2rem; /* Increased height proportionally */
        }
    }
</style>
