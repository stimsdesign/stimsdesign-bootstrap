---
import { Image } from "astro:assets";
import Devices from "/src/assets/images/hero-devices.png";
import Logo from "../elements/Logo.astro";
import Waves from "../elements/Waves.astro";
import Button from "../elements/Button.astro";
import Ticker from "../elements/Ticker.astro";
---

<section id="hero-section">
    <div id="hero-wrapper">
        <a href="tel:+14807085204" class="phone-link" aria-label="Call Today (480) 708-5204"><span>Click to Call</span></a>
        <div id="hero">
            <div id="hero-text">
                <Logo maxWidth="100%" margin="0 0 1.5rem 0" />
                <h1 class="fire">Empowering SMBs with Tools & Stunning Websites to Succeed</h1>
                <p>A website isn’t just a digital footprint—it’s a growth engine. I craft conversion-focused websites that integrate with your entire tech stack and empower your business to make measurable improvements to your bottom line.<br />— Stephen Tims</p>
                <div class="buttons">
                    <Button href="#why-choose" bookmark>Why Choose?</Button>
                    <Button href="/estimate.html">Get a "Quote"</Button>
                </div>
            </div>
            <div class="hero-image">
                <Image alt="Devices" src={Devices} />
            </div>
        </div>
        <Waves color="var(--color-secondary-dark)" />
        <Ticker>
            <span class="wordpress">Wordpress</span>
            <span class="shopify">Shopify</span>
            <span class="astro">Astro</span>
            <span class="eleventy">Eleventy</span>
            <span class="netlify">Netlify</span>
            <span class="akamai">Akamai</span>
            <span class="illustrator">Illustrator</span>
            <span class="photoshop">Photoshop</span>
            <span class="aftereffects">After Effects</span>
            <span class="premierepro">Premiere Pro</span>
            <span class="nginx">Nginx</span>
            <span class="apache">Apache</span>
            <span class="html5">HTML5</span>
            <span class="css3">CSS3</span>
            <span class="javascript">JavaScript</span>
            <span class="react">React</span>
            <span class="nodejs">Node.js</span>
            <span class="php">PHP</span>
            <span class="mysql">MySQL</span>
            <span class="postgres">PostgreSQL</span>
            <span class="google">Google Analytics</span>
            <span class="openai">OpenAI</span>
            <span class="gemini">Gemini</span>
            <span class="salesforce">Salesforce</span>
            <span class="slack">Slack</span>
            <span class="jira">Jira</span>
            <span class="facebook-business">Facebook Business</span>
            <span class="google">Google Ads</span>
            <span class="mailchimp">Mailchimp</span>
        </Ticker>
    </div>
</section>

<style>
    #hero-section {
        min-height: calc(100dvh - 2rem);
        overflow: hidden;
        background-color: var(--color-secondary-dark);
        container-type: inline-size;
        container-name: hero;
    }

    .phone-link {
        display: none;
    }

    @media (max-width: 768px) {
        .phone-link {
            display: block;
            position: absolute;
            max-width: 50%;
            height: 40px; /* Reference height */
