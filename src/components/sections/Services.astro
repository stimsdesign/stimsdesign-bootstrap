---
import Slider from "../elements/Slider.astro";
---

<section id="services" data-zoom>
    <div class="zoom-content">
        <div>
            <h1>What can STIMS Design <span>do for your business?</span></h1>
            <p>I provide a range of digital services designed to help your business thrive, backed by more than <span class="bold fire">20 years of experience</span>. Explore the core areas where I can deliver meaningful impact:</p>
            <Slider pagination bulletColor="var(--color-foreground)" autoplay>
                <div class="slide-headers">
                    <h3><span>Web&nbsp;Dev <span class="break">&amp;&nbsp;Design</span><span class="ripple"></span></span></h3>
                    <h3><span>Digital <span class="break">Solutions</span><span class="ripple"></span></span></h3>
                    <h3><span>Graphic <span class="break">Design</span><span class="ripple"></span></span></h3>
                </div>
                <div id="web-development-slide" class="slide">
                    <ul>
                        <li id="service-marketing">
                            <a href="/services.html#web-dev">Marketing & Conversion</a>
                            <ul>
                                <li>Landing pages</li>
                                <li>Brochure websites</li>
                                <li>Lead capture websites</li>
                                <li>Corporate websites</li>
                                <li>Portfolio websites</li>
                                <li>Blogs & content systems</li>
                            </ul>
                        </li>
                        <li id="service-ecommerce">
                            <a href="/services.html#web-dev">E-Commerce Solutions</a>
                            <ul>
                                <li>Online storefronts</li>
                                <li>Subscription/membership</li>
                                <li>Product catalog systems</li>
                                <li>Payment gateways</li>
                                <li>Marketplace Integrations</li>
                                <li>Multi-vendor platforms</li>
                            </ul>
                        </li>
                        <li id="service-booking">
                            <a href="/services.html#web-dev">Booking & Events</a>
                            <ul>
                                <li>Appointment booking</li>
                                <li>Scheduling platforms</li>
                                <li>Event registration</li>
                                <li>Ticketing websites</li>
                                <li>Calendar integrations</li>
                                <li>Virtual events</li>
                            </ul>
                        </li>
                        <li id="service-real-estate">
                            <a href="/services.html#web-dev">Real Estate</a>
                            <ul class="short-list">
                                <li>Property listing websites</li>
                                <li>Agent & agency websites</li>
                                <li>Virtual tour integration</li>
                                <li>Rental availability websites</li>
                            </ul>
                        </li>
                        <li id="service-community">
                            <a href="/services.html#web-dev">Community Engagement</a>
                            <ul class="short-list">
                                <li>Membership websites</li>
                                <li>Social communities</li>
                                <li>Directory & listing websites</li>
                                <li>Forums & discussion systems</li>
                            </ul>
                        </li>
                        <li id="service-education">
                            <a href="/services.html#web-dev">Educational Training</a>
                            <ul class="short-list">
                                <li>Online course platforms</li>
                                <li>Learning modules</li>
                                <li>Interactive testing</li>
                                <li>Certification systems</li>
                            </ul>
                        </li>
                    </ul>
                </div>
                <div id="digital-solutions-slide" class="slide">
                    <ul>
                        <li id="service-strategy">
                            <a href="/services.html#digital-solutions">Strategy & Consulting</a>
                            <ul>
                                <li>Web presence audits</li>
                                <li>Website Deliverables</li>
                                <li>Journey mapping</li>
                                <li>launch roadmaps</li>
                                <li>Strategy reviews</li>
                                <li>Certified IT Support</li>
                            </ul>
                        </li>
                        <li id="service-crm">
                            <a href="/services.html#digital-solutions">CRM Integrations</a>
                            <ul>
                                <li>Selection & setup</li>
                                <li>Sales pipeline</li>
                                <li>Lead routing</li>
                                <li>Automated follow-ups</li>
                                <li>Proposal Automation</li>
                                <li>Activity tracking</li>
                            </ul>
                        </li>
                        <li id="service-automation">
                            <a href="/services.html#digital-solutions">Workflow Automation</a>
                            <ul class="short-list">
                                <li>Lead intake & qualification</li>
                                <li>Triggered Notifications</li>
                                <li>Dispatch Routing</li>
                                <li>Appointment Booking</li>
                            </ul>
                        </li>
                        <li id="service-cusrtomer-support">
                            <a href="/services.html#digital-solutions">Customer Support</a>
                            <ul>
                                <li>Customer Accounts</li>
                                <li>Online FAQs</li>
                                <li>AI-assisted chatbots</li>
                                <li>Feedback systems</li>
                                <li>Support ticket intake</li>
                                <li>Warranty registration</li>
                            </ul>
                        </li>
                        <li id="service-internal">
                            <a href="/services.html#digital-solutions">Staff Support</a>
                            <ul>
                                <li>Knowledge bases</li>
                                <li>Ticketing Systems</li>
                                <li>Onboarding Portals</li>
                                <li>Job Application Forms</li>
                                <li>Training modules</li>
                                <li>Interactive Checklists</li>
                            </ul>
                        </li>
                        <li id="service-operations">
                            <a href="/services.html#digital-solutions">Internal Operations</a>
                            <ul class="short-list">
                                <li>Custom dashboards</li>
                                <li>Intranet websites</li>
                                <li>Employee resource hubs</li>
                                <li>SOP & training portals</li>
                            </ul>
                        </li>
                    </ul>
                </div>
                <div id="visual-media-slide" class="slide">
                    <ul>
                        <li id="service-branding">
                            <a href="/services.html#graphic-design">Branding</a>
                            <ul>
                                <li>Logo design</li>
                                <li>Brand audit</li>
                                <li>Brand identity strategy</li>
                                <li>Rebranding</li>
                                <li>Business cards</li>
                                <li>Stationery design</li>
                            </ul>
                        </li>
                        <li id="service-creative">
                            <a href="/services.html#graphic-design">Marketing Creative</a>
                            <ul>
                                <li>Digital ad design</li>
                                <li>Print ad design</li>
                                <li>Email campaign design</li>
                                <li>Banner & poster design</li>
                                <li>Infographics</li>
                                <li>Presentation design</li>
                            </ul>
                        </li>
                        <li id="service-social">
                            <a href="/services.html#graphic-design">Social Content</a>
                            <ul class="short-list">
                                <li>Social media templates</li>
                                <li>Reel & story templates</li>
                                <li>Channel branding</li>
                                <li>Video thumbnails</li>
                            </ul>
                        </li>
                        <li id="service-uiux">
                            <a href="/services.html#graphic-design">UI/UX Design</a>
                            <ul class="short-list">
                                <li>Web app design</li>
                                <li>Mobile app design</li>
                                <li>User flows & wireframes</li>
                                <li>Component libraries</li>
                            </ul>
                        </li>
                        <li id="service-digitalassets">
                            <a href="/services.html#graphic-design">Digital Assets</a>
                            <ul>
                                <li>Hero visuals & website graphics</li>
                                <li>Custom icons & illustrations</li>
                                <li>Process diagrams & explainer graphics</li>
                                <li>Video production & editing</li>
                                <li>Motion graphics</li>
                                <li>Photography</li>
                            </ul>
                        </li>
                        <li id="service-copywriting">
                            <a href="/services.html#graphic-design">Copywriting</a>
                            <ul>
                                <li>Website content copy</li>
                                <li>Blog posts</li>
                                <li>Social media copy</li>
                                <li>Ad copy</li>
                                <li>Email copy</li>
                                <li>Product descriptions</li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </Slider>
        </div>
    </div>
</section>

<style>
    #services {
        min-height: 100dvh;
        padding-bottom: 2rem;
        background: linear-gradient(
            to bottom,
            var(--color-secondary-dark) 0%,
            var(--color-secondary) 20%,
            var(--color-secondary) 70%,
            var(--color-secondary-dark) 100%
        );
    }

    @media (max-width: 768px) {
        #services {
            padding-bottom: 2rem;
        }
    }

    .zoom-content {
        height: 100%;
        transform-origin: center top;
        will-change: transform;
        animation: zoomer linear;
        animation-timeline: view();
        animation-range-start: cover;
        animation-range-end: 80dvh;
        padding-top: 2rem;
    }

    @keyframes zoomer {
        from {
            scale: 0.5;
        }
        to {
            scale: 1;
        }
    }

    .zoom-content > div {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        overflow: hidden;
    }

    #services h1 {
        color: white;
        filter: drop-shadow(1px 1px 4px rgba(255, 255, 255, 0.4));
        width: clamp(94%, 100% - 10cqi, 75ch);
        margin: 0 auto 1rem;
        text-align: center;
    }

    #services h1 span {
        display: block;
        color: white;
        font-size: var(--size-2xl);
        line-height: 1em;
        text-align: center;
    }

    #services p {
        font-size: var(--size-lg);
        color: white;
        margin-bottom: 6cqi;
        text-align: center;
        max-width: 70ch;
    }

    @media (max-width: 768px) {
        #services p {
            max-width: 90%;
        }
    }

    .slide-headers {
        display: flex;
        text-align: center;
        position: relative;
        gap: 2rem;
    }

    .slide-headers h3 {
        flex: 1;
        position: relative;
        font-size: var(--size-xl);
        font-weight: var(--weight-black);
        color: var(--color-foreground);
        cursor: pointer;
        transition: opacity 0.3s ease;
        margin: 0;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.4);
        opacity: 0.5;
    }

    @media (max-width: 1600px) {
        .slide-headers .break {
            display: block;
        }
    }

    .slide-headers h3:hover,
    .slide-headers h3.active {
        opacity: 1;
    }

    .slide-headers h3:nth-child(1) {
        color: var(--color-accent);
    }
    .slide-headers h3:nth-child(1) .ripple {
        background: var(--color-accent-lighter);
    }
    .slide-headers h3:nth-child(1) .ripple:before,
    .slide-headers h3:nth-child(1) .ripple:after {
        background: var(--color-accent-lighter);
    }
    .slide-headers h3:nth-child(2) {
        color: var(--color-primary-dark);
    }
    .slide-headers h3:nth-child(2) .ripple {
        background: var(--color-primary);
    }
    .slide-headers h3:nth-child(2) .ripple:before,
    .slide-headers h3:nth-child(2) .ripple:after {
        background: var(--color-primary);
    }
    .slide-headers h3:nth-child(3) {
        color: var(--color-foreground);
    }
    .slide-headers h3:nth-child(3) .ripple {
        background: var(--color-foreground-dark);
    }
    .slide-headers h3:nth-child(3) .ripple:before,
    .slide-headers h3:nth-child(3) .ripple:after {
        background: var(--color-foreground-dark);
    }
    .slide-headers h3 > span {
        position: relative;
        display: inline-block; /* <-- key change */
        text-align: center;
    }

    .ripple {
        display: block;
        position: absolute;
        width: 50px;
        height: 50px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        -webkit-backface-visibility: hidden;
        z-index: -1;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .slide-headers h3:hover .ripple,
    .slide-headers h3.active .ripple {
        opacity: 0.5;
    }

    .ripple:before {
        position: absolute;
        top: 0;
        left: 0;
        margin-left: -25px;
        margin-top: -25px;
        width: 100px;
        height: 100px;
        content: "";
        display: block;
        border-radius: 50%;
        -webkit-backface-visibility: hidden;
        animation: ripple-animate 3s infinite ease-out;
    }

    .ripple:after {
        position: absolute;
        top: 0;
        left: 0;
        margin-left: -25px;
        margin-top: -25px;
        width: 100px;
        height: 100px;
        content: "";
        display: block;
        border-radius: 50%;
        -webkit-backface-visibility: hidden;
        opacity: 0;
        animation: ripple-animate 3s 1.5s infinite ease-out;
    }

    @keyframes ripple-animate {
        0% {
            transform: scale(0);
            opacity: 1;
            transform-origin: center;
        }
        100% {
            transform: scale(3);
            opacity: 0;
            transform-origin: center;
        }
    }

    .slide {
        padding: 4rem 0 6rem;
    }

    @media (max-width: 768px) {
        .slide {
            padding: 3rem 0 4rem;
        }
    }

    .slide > ul {
        max-width: clamp(94%, 100% - 10cqi, 1440px);
        margin: 0 auto;
        list-style: none;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        row-gap: 3rem;
        column-gap: 2rem;
    }

    @media (max-width: 768px) {
        .slide > ul {
            grid-template-columns: repeat(2, 1fr);
            row-gap: 2rem;
            column-gap: 1rem;
        }
    }

    /* @media (max-width: 400px) {
        .slide > ul {
            grid-template-columns: 1fr;
        }
    } */

    .slide > ul > li {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

    .slide > ul > li > a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        font-weight: bold;
        text-decoration: none;
        color: white;
        font-size: var(--size-xl);
        text-transform: uppercase;
        text-align: center;
        font-family: var(--family-heading);
        padding-top: calc(128px + 1rem);
        background-size: 128px;
        background-position: top center;
        background-repeat: no-repeat;
    }

    #service-marketing a {
        background-image: url("images/target.png");
    }
    #service-ecommerce a {
        background-image: url("images/shopping-cart.png");
    }
    #service-booking a {
        background-image: url("images/booking.png");
    }
    #service-real-estate a {
        background-image: url("images/realestate-sale.png");
    }
    #service-community a {
        background-image: url("images/community.png");
    }
    #service-education a {
        background-image: url("images/education.png");
    }
    #service-strategy a {
        background-image: url("images/compass.png");
    }
    #service-crm a {
        background-image: url("images/puzzle.png");
    }
    #service-automation a {
        background-image: url("images/automation.png");
    }
    #service-cusrtomer-support a {
        background-image: url("images/customer-support.png");
    }
    #service-internal a {
        background-image: url("images/id-badge.png");
    }
    #service-operations a {
        background-image: url("images/checklist.png");
    }
    #service-branding a {
        background-image: url("images/abstract-logo.png");
    }
    #service-creative a {
        background-image: url("images/creative.png");
    }
    #service-social a {
        background-image: url("images/like.png");
    }
    #service-uiux a {
        background-image: url("images/uxui.png");
    }
    #service-digitalassets a {
        background-image: url("images/assets.png");
    }
    #service-copywriting a {
        background-image: url("images/copy.png");
    }

    .slide ul ul {
        display: block;
        list-style: none;
        margin: 0;
        padding: 0;
        height: 1.5em; /* Just enough for one line of text */
        z-index: 2;
        pointer-events: none;
        position: relative;
        width: 100%;
    }

    .slide ul ul li {
        font-size: var(--size-md);
        white-space: nowrap;
        text-transform: capitalize;
        margin: 0;
        padding: 0;
        text-align: center;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        opacity: 0;
        color: white;
    }

    .slide.active ul ul li:nth-child(1) {
        animation: fadeinout 12s linear 0s infinite;
    }
    .slide.active ul ul li:nth-child(2) {
        animation: fadeinout 12s linear 2s infinite;
    }
    .slide.active ul ul li:nth-child(3) {
        animation: fadeinout 12s linear 4s infinite;
    }
    .slide.active ul ul li:nth-child(4) {
        animation: fadeinout 12s linear 6s infinite;
    }
    .slide.active ul ul li:nth-child(5) {
        animation: fadeinout 12s linear 8s infinite;
    }
    .slide.active ul ul li:nth-child(6) {
        animation: fadeinout 12s linear 10s infinite;
    }

    /* Short list loops every 8s (4 items * 2s) while full list loops every 12s.
       Absolute fade timings align (appear ~0.24s, visible until 1.68s, gone by 2s of each slot). */
    .slide.active ul ul.short-list li:nth-child(1) {
        animation: fadeinoutShort 8s linear 0s infinite;
    }
    .slide.active ul ul.short-list li:nth-child(2) {
        animation: fadeinoutShort 8s linear 2s infinite;
    }
    .slide.active ul ul.short-list li:nth-child(3) {
        animation: fadeinoutShort 8s linear 4s infinite;
    }
    .slide.active ul ul.short-list li:nth-child(4) {
        animation: fadeinoutShort 8s linear 6s infinite;
    }

    @keyframes fadeinoutShort {
        0% {
            opacity: 0;
        }
        3% {
            opacity: 1;
        } /* ~0.24s */
        21% {
            opacity: 1;
        } /* ~1.68s */
        25% {
            opacity: 0;
        } /* 2s */
        100% {
            opacity: 0;
        }
    }

    @keyframes fadeinout {
        0% {
            opacity: 0;
        }
        2% {
            opacity: 1;
        }
        14% {
            opacity: 1;
        }
        16.666% {
            opacity: 0;
        }
        100% {
            opacity: 0;
        }
    }
</style>
