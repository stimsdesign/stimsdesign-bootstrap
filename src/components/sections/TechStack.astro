const rotationStep = 360 / brandList.length;
---

<section id="techstack">
    <div class="tech-wrapper">
        <div class="tech-container">
            <div class="content-left">
                <h1>Your <span class="nowrap">Tech Stack</span> <span class="highlight">Connected</span></h1>
                <p>Modernize outdated systems or build a powerful new digital foundation. Connect essential tools, secure sensitive data, and scale operations in the cloud. Automate workflows to speed up delivery, cut unnecessary costs, and ensure everything runs smoothly 24/7.</p>
                <p>Integrate your front-end and back-end technologies to create a seamless user experience.</p>
                <div>
                    <Button alt="orange" href="/estimate.html">Start Your Project</Button>
                </div>
                <div class="tech-list-mobile">
                    {
                        brandList.map((item) => (
                            <div class="mobile-icon">
                                <Fragment set:html={item.icon} />
                                <span>{item.name}</span>
                            </div>
                        ))
                    }
                </div>
            </div>
            <div class="visual-right">
                <div class="orbital-system">
                    <div class="connector-lines">
                        {
                            brandList.map((_, i) => (
                                <div class={`line line-${i}`} style={`--rotation: ${i * rotationStep}deg`} />
                            ))
                        }
                    </div>
                    <div class="center-hub">
                        <Image src={TechStackImg} alt="Abstract Brain Tech Hub" class="brain-graphic" />
                    </div>
                    <div class="orbit">
                        {
                            brandList.map((item, i) => (
                                <div class="orbit-node" style={`--index: ${i}; --total: ${brandList.length}`}>
                                    <div class="node-logo">
                                        <Fragment set:html={item.icon} />
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    #techstack {
        /* Updated to secondary blue to match adjacent sections */
        background-color: var(--color-secondary-dark);
        overflow: hidden;
    }

    .tech-wrapper {
        background-color: var(--color-foreground);
        color: var(--color-background);
        border-radius: 15vw 0 0 15vw;
        min-height: 90dvh;
        display: flex;
        align-items: center;
        width: 100%;
    }

    .tech-container {
        width: clamp(94%, 100% - 10cqi, 1440px);
        max-width: 1600px;
        margin: 0 auto;
        padding: clamp(4rem, 5vh, 5cqi) 4rem;
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 6rem;
        align-items: center;
    }

    .content-left {
        z-index: 10;
    }

    .content-left h1 {
        line-height: 1;
        margin-bottom: 2rem;
        color: var(--color-foreground-darker);
    }

    .highlight {
        color: var(--color-secondary);
        text-shadow: 2px 2px 0px rgba(8, 139, 208, 0.1);
    }

    .content-left p {
        color: black;
        max-width: 60ch;
        line-height: 1.5;
        opacity: 0.9;
    }

    .content-left p:last-of-type {
        margin-bottom: 3rem;
    }

    /* Orbital System */
    .visual-right {
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        /* min-height: 800px; */
    }

    .orbital-system {
        position: relative;
        /* Define container size variable for reuse in radius calculation */
        --container-size: clamp(280px, 50vw, 750px);
        width: var(--container-size);
        height: var(--container-size);

        display: flex;
        justify-content: center;
        align-items: center;
    }

    .center-hub {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 55%;
        height: 55%;
        z-index: 5;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .brain-graphic {
        width: 100%;
        height: 100%;
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    .orbit {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        box-sizing: border-box;
        border: 2px dashed rgba(2, 76, 170, 0.15);
        border-radius: 50%;
        animation: rotateOrbit 60s linear infinite;
        pointer-events: none;
    }

    .orbit-node {
        position: absolute;
        top: 50%;
        left: 50%;
        --angle: calc(var(--index) * (360deg / var(--total)));
        /* Radius calculation based on container size (half of width) */
        --radius: calc(var(--container-size) / 2);
        transform: translate(-50%, -50%) rotate(var(--angle))
            translateY(calc(-1 * var(--radius))) rotate(calc(-1 * var(--angle)));
        animation: counterRotate 60s linear infinite;
    }

    .node-logo {
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: all 0.3s ease;
        width: 100px;
        height: 100px;
        aspect-ratio: 1;
    }

    .node-logo:hover {
        transform: scale(1.15);
    }

    .node-logo svg {
        width: 100%;
        height: 100%;
        /* Orange Icon */
        color: var(--color-accent);
        transition: transform 0.3s ease;
    }

    .node-logo:hover svg {
        transform: scale(1.1);
    }

    /* Connector Lines */
    .connector-lines {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 100%;
        height: 100%;
        transform: translate(-50%, -50%);
        pointer-events: none;
    }

    .line {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 50%;
        height: 2px;
        background: linear-gradient(
            90deg,
            rgba(2, 76, 170, 0.2),
            /* secondary with opacity */ transparent
        );
        transform-origin: left center;
        transform: rotate(calc(var(--rotation) - 90deg));
    }

    /* Mobile Tech List */
    .tech-list-mobile {
        display: none;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-top: 3rem;
    }

    .mobile-icon {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background: rgba(2, 76, 170, 0.05);
        border-radius: 12px;
        border: 1px solid rgba(2, 76, 170, 0.1);
    }

    .mobile-icon svg {
        width: 28px;
        height: 28px;
        color: var(--color-accent);
    }

    .mobile-icon span {
        font-weight: 700;
        color: var(--color-primary-dark);
    }

    /* Animations */
    @keyframes rotateOrbit {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }

    @keyframes counterRotate {
        from {
            transform: translate(-50%, -50%) rotate(var(--angle))
                translateY(calc(-1 * var(--radius)))
                rotate(calc(-1 * var(--angle) - 0deg));
        }
        to {
            transform: translate(-50%, -50%) rotate(var(--angle))
                translateY(calc(-1 * var(--radius)))
                rotate(calc(-1 * var(--angle) - 360deg));
        }
    }

    /* Responsive */
    @media (min-width: 1440px) {
        .node-logo {
            width: 120px;
            height: 120px;
        }

        .node-logo svg {
            width: 64px;
            height: 64px;
        }
    }

    @media (max-width: 1200px) {
        .tech-container {
            padding: clamp(4rem, 5vh, 5cqi) 2rem;
            grid-template-columns: 1fr;
            text-align: center;
            gap: 4rem;
        }

        .content-left p {
            margin: 0 auto;
        }

        .content-left p:first-of-type {
            margin: 0 auto 1.5rem;
        }
    }

    @media (max-width: 768px) {
        .tech-container {
            padding: clamp(2rem, 5vh, 2cqi) 2rem 4rem;
        }

        .orbital-system {
            /* Use a larger percentage of the viewport on small screens */
            --container-size: clamp(260px, 75vw, 500px);
        }

        .node-logo {
            width: 60px; /* Scale down the logos so they fit the smaller orbit */
            height: 60px;
        }

        .center-hub {
            width: 60%; /* Increase brain size slightly relative to smaller orbit */
            height: 60%;
        }
    }

    @media (max-width: 480px) {
        .orbital-system {
            --container-size: 220px;
        }
        .node-logo {
            width: 50px;
            height: 50px;
        }
    }
</style>
