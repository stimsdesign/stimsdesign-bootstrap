<script>
    function rgbToHex(rgbStr: string): string {
        if (!rgbStr) return "";
        const match = rgbStr.match(/^rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)$/);
        if (!match) return rgbStr;
        const r = parseInt(match[1]).toString(16).padStart(2, '0');
        const g = parseInt(match[2]).toString(16).padStart(2, '0');
        const b = parseInt(match[3]).toString(16).padStart(2, '0');
        return `#${r}${g}${b}`.toUpperCase();
    }

    function copyToClipboard(text: string): Promise<void> {
        if (navigator.clipboard && navigator.clipboard.writeText) {
            return navigator.clipboard.writeText(text);
        } else {
            const textarea = document.createElement("textarea");
            textarea.value = text;
            textarea.style.position = "fixed";
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand("copy");
            } catch (err) {
                console.error("Fallback copy failed", err);
            }
            document.body.removeChild(textarea);
            return Promise.resolve();
        }
    }

    function showTooltip(element: HTMLElement, text: string) {
        const existing = document.querySelectorAll('.copied-tooltip');
        existing.forEach(t => t.remove());

        const tooltip = document.createElement('div');
        tooltip.className = 'copied-tooltip';
        tooltip.textContent = text;
        
        document.body.appendChild(tooltip);

        const rect = element.getBoundingClientRect();
        const scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        
        tooltip.style.left = `${rect.left + rect.width / 2 + scrollLeft}px`;
        tooltip.style.top = `${rect.top - 10 + scrollTop}px`;

        requestAnimationFrame(() => {
            tooltip.classList.add('visible');
        });

        setTimeout(() => {
            tooltip.classList.remove('visible');
            tooltip.addEventListener('transitionend', () => {
                tooltip.remove();
            }, { once: true });
        }, 1000);
    }

    // Scans page stylesheets to find and resolve custom variables (--color-* and --font-*)
    function getCSSVariables() {
        const variables = {
            colors: [] as Array<{ name: string; value: string }>,
            fonts: [] as Array<{ name: string; value: string }>
        };
        const computedStyles = getComputedStyle(document.documentElement);
        const seen = new Set<string>();

        // Loop through all stylesheets accessible in document
        for (const sheet of Array.from(document.styleSheets)) {
            try {
                const rules = Array.from(sheet.cssRules || sheet.rules || []);
                for (const rule of rules) {
                    if (rule.cssText) {
                        // Regex search for declared variable names (e.g. --color-primary: ...)
                        const varRegex = /(--[\w-]+)\s*:/g;
                        let match;
                        while ((match = varRegex.exec(rule.cssText)) !== null) {
                            const prop = match[1];
                            if (seen.has(prop)) continue;
                            seen.add(prop);

                            // Retrieve browser-resolved computed value of CSS custom variable
                            const val = computedStyles.getPropertyValue(prop).trim();
                            if (prop.startsWith('--color-')) {
                                variables.colors.push({ name: prop, value: val });
                            } else if (prop.startsWith('--font-')) {
                                variables.fonts.push({ name: prop, value: val });
                            }
                        }
                    }
                }
            } catch (e) {
                // CORS or loading errors, ignore
            }
        }
        return variables;
    }

    // Standardizes color output value formatting (e.g., adding spaces after commas, color-mix values)
    function formatValueDisplay(val: string): string {
        if (!val) return "";
        return val
            .replace(/,/g, ", ")
            .replace(/color-mix\(insrgb/g, "color-mix(in srgb")
            .replace(/transparent/g, "transparent ")
            .replace(/\s+/g, " ")
            .trim();
    }

    function renderThemeCalibration() {
        const swatchesGrid = document.getElementById("auto-swatches-grid");
        const fontsList = document.getElementById("auto-fonts-list");
        if (!swatchesGrid || !fontsList) return;

        const vars = getCSSVariables();

        // Deduplicate fonts by computed value (retaining the first matching declaration order, e.g. heading/body/accent)
        const fontValueSeen = new Set<string>();
        const uniqueFonts: Array<{ name: string; value: string }> = [];
        vars.fonts.forEach(font => {
            const normalizedValue = font.value.replace(/['"]/g, "").toLowerCase();
            if (!fontValueSeen.has(normalizedValue)) {
                fontValueSeen.add(normalizedValue);
                uniqueFonts.push(font);
            }
        });

        // 1. Render Swatches
        if (vars.colors.length > 0) {
            swatchesGrid.innerHTML = "";
            vars.colors.forEach(color => {
                const card = document.createElement("div");
                card.className = "swatch-card";
                
                const preview = document.createElement("div");
                preview.className = "swatch-preview";
                preview.style.backgroundColor = `var(${color.name})`;
                
                const info = document.createElement("div");
                info.className = "swatch-info";
                
                const nameSpan = document.createElement("span");
                nameSpan.className = "swatch-name";
                nameSpan.textContent = color.name;
                
                const valSpan = document.createElement("span");
                valSpan.className = "swatch-value";
                valSpan.textContent = formatValueDisplay(color.value);
                
                info.appendChild(nameSpan);
                info.appendChild(valSpan);
                card.appendChild(preview);
                card.appendChild(info);
                
                card.addEventListener("click", (e) => {
                    const isAltOrCtrl = e.ctrlKey || e.altKey || e.metaKey;
                    let textToCopy = color.name;
                    let tooltipText = "Copied Var!";

                    if (isAltOrCtrl) {
                        const computedColor = getComputedStyle(preview).backgroundColor;
                        textToCopy = rgbToHex(computedColor);
                        tooltipText = `Copied Hex: ${textToCopy}`;
                    }

                    copyToClipboard(textToCopy).then(() => {
                        showTooltip(card, tooltipText);
                    });
                });
                
                swatchesGrid.appendChild(card);
            });
        } else {
            swatchesGrid.innerHTML = '<p class="xsmall" style="color: var(--color-red);">No --color-* variables found in style sheets.</p>';
        }

        // 2. Render Font Testers
        if (uniqueFonts.length > 0) {
            fontsList.innerHTML = "";
            uniqueFonts.forEach(font => {
                // Remove quotes and fallbacks to extract main display name
                let cleanFontName = font.value.replace(/['"]/g, "").split(",")[0].trim();
                // Strip Vite/Astro hash suffixes (e.g. "-b4c0cc156864eee1")
                cleanFontName = cleanFontName.replace(/-[a-f0-9]{16}$/i, "");
                
                const card = document.createElement("div");
                card.className = "font-test-card";
                
                const preview = document.createElement("div");
                preview.className = "font-preview";
                preview.style.fontFamily = `var(${font.name})`;
                
                const suffix = ` ${font.name}`;
                const defaultText = `${cleanFontName}${suffix}`;
                preview.textContent = defaultText;
                
                const input = document.createElement("input");
                input.type = "text";
                input.placeholder = `Type to test ${cleanFontName}...`;
                input.className = "font-test-input";
                input.setAttribute("data-default", defaultText);
                
                input.addEventListener("input", (e) => {
                    const target = e.target as HTMLInputElement;
                    const val = target.value.trim();
                    preview.textContent = val ? `${val}${suffix}` : defaultText;
                });
                
                preview.addEventListener("click", () => {
                    const textToCopy = font.name;
                    copyToClipboard(textToCopy).then(() => {
                        showTooltip(preview, "Copied Var!");
                    });
                });
                
                card.appendChild(preview);
                card.appendChild(input);
                fontsList.appendChild(card);
            });
        } else {
            fontsList.innerHTML = '<p class="xsmall" style="color: var(--color-red);">No --font-* variables found in style sheets.</p>';
        }
    }

    function setupCollapsibleSections() {
        const titles = document.querySelectorAll(".dev-html-elements .section-title");
        titles.forEach(title => {
            const section = title.closest("section");
            if (!section) return;

            const titleText = title.textContent || "";
            const storageKey = "section-collapsed-" + titleText.trim().toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");

            try {
                if (typeof localStorage !== "undefined") {
                    const isCollapsed = localStorage.getItem(storageKey);
                    if (isCollapsed === "true") {
                        section.classList.add("collapsed");
                    } else if (isCollapsed === "false") {
                        section.classList.remove("collapsed");
                    }
                }
            } catch (e) {
                console.warn("Could not read from localStorage", e);
            }

            title.addEventListener("click", () => {
                const nowCollapsed = section.classList.toggle("collapsed");
                try {
                    if (typeof localStorage !== "undefined") {
                        localStorage.setItem(storageKey, nowCollapsed ? "true" : "false");
                    }
                } catch (e) {
                    console.warn("Could not write to localStorage", e);
                }
            });
        });
    }

    // Run calibration and setups on load and transitions
    document.addEventListener("astro:page-load", () => {
        renderThemeCalibration();
        setupCollapsibleSections();
    });
</script>