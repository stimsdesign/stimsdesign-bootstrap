---
import Slider from "../elements/Slider.astro";
import BistroCard from "../cards/Bistro.astro";
import VintageCard from "../cards/Vintage.astro";
import HandyManCard from "../cards/HandyMan.astro";
import Dollar from "../../icons/dollar.svg";
---

<section id="save-money">
    <div class="content">
        <!-- Background Animations Layer -->
        <div class="animation-container" aria-hidden="true">
            <!-- Raining Money -->
            {
                [...Array(5)].map((_, i) => (
                    <div class="money" style={`
                            --delay: ${i * 1.5}s; 
                            --left-1: ${5 + Math.random() * 80}vw; 
                            --left-2: ${Math.random() * 80}vw; 
                            --left-3: ${10 + Math.random() * 80}vw; 
                            --scale: ${0.8 + Math.random() * 0.4}; 
                            --rotation: ${Math.random() * 360}deg; 
                            --drift-x: ${Math.random() * 60 - 30}px;`}
                    >
                        <Dollar />
                    </div>
                ))
            }
        </div>

        <div class="inner-content">
            <hgroup>
                <h1><span class="nowrap">Save Money &bull;</span> <span class="fire">Do More!</span></h1>
                <p>Reclaim your operating costs and focus on what you do best.</p>
            </hgroup>
            <Slider arrows pagination bulletColor="var(--color-foreground)" continuous>
                <HandyManCard />
                <VintageCard />
                <BistroCard />
            </Slider>
        </div>
    </div>
</section>

<style>
    #save-money {
        background: linear-gradient(
            to bottom,
            var(--color-foreground) 50%,
            var(--color-primary-darker) 50%
        );
        position: relative;
        overflow: hidden;
    }

    #save-money > .content {
        min-height: 100dvh;
        background-color: var(--color-secondary-dark);
        border-radius: 0 14vw 14vw 0;
        position: relative;
        z-index: 2;
        overflow: hidden;
        padding: 0 0 2rem;
    }

    .inner-content {
        position: relative;
        z-index: 10;
    }

    hgroup {
        padding: 4rem 0 3rem;
    }

    hgroup h1 {
        text-align: center;
        margin-bottom: 1rem;
        color: var(--color-foreground);
        filter: drop-shadow(1px 1px 4px rgba(255, 255, 255, 0.4));
    }

    hgroup p {
        max-width: 60ch;
        text-align: center;
        color: var(--color-foreground);
        filter: drop-shadow(1px 1px 4px rgba(255, 255, 255, 0.4));
        font-size: var(--size-lg);
        margin: 0 auto;
    }

    .animation-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
        overflow: hidden;
    }

    .money {
        position: absolute;
        top: -120px;
        left: 0;
        width: clamp(120px, 16vw, 240px);
        height: auto;
        fill: var(--color-accent);
        opacity: 0;
        animation: rain-multi 22.5s linear infinite;
        animation-delay: var(--delay);
        will-change: transform, opacity;
    }

    @keyframes rain-multi {
        /* Phase 1: */
        0% {
            transform: translate3d(var(--left-1), 0, 0) scale(var(--scale))
                rotate(var(--rotation));
            opacity: 0;
        }
        2% {
            opacity: 0.7;
        }
        25% {
            opacity: 0.7;
        }
        31% {
            transform: translate3d(
                    calc(var(--left-1) + var(--drift-x)),
                    90vh,
                    0
                )
                scale(var(--scale)) rotate(calc(var(--rotation) + 360deg));
            opacity: 0;
        }

        /* Phase 2: Switch to --left-2 */
        32% {
            transform: translate3d(var(--left-2), 0, 0) scale(var(--scale))
                rotate(var(--rotation));
            opacity: 0;
        }
        33.33% {
            transform: translate3d(var(--left-2), 0, 0) scale(var(--scale))
                rotate(var(--rotation));
            opacity: 0;
        }
        35.33% {
            opacity: 0.7;
        }
        58.33% {
            opacity: 0.7;
        }
        64.33% {
            transform: translate3d(
                    calc(var(--left-2) - (var(--drift-x) * 0.5)),
                    90vh,
                    0
                )
                scale(var(--scale)) rotate(calc(var(--rotation) + 360deg));
            opacity: 0;
        }

        /* Phase 3: Switch to --left-3 */
        65.33% {
            transform: translate3d(var(--left-3), 0, 0) scale(var(--scale))
                rotate(var(--rotation));
            opacity: 0;
        }
        66.66% {
            transform: translate3d(var(--left-3), 0, 0) scale(var(--scale))
                rotate(var(--rotation));
            opacity: 0;
        }
        68.66% {
            opacity: 0.7;
        }
        91.66% {
            opacity: 0.7;
        }
        98% {
            transform: translate3d(
                    calc(var(--left-3) + (var(--drift-x) * 0.5)),
                    90vh,
                    0
                )
                scale(var(--scale)) rotate(calc(var(--rotation) + 360deg));
            opacity: 0;
        }
        100% {
            transform: translate3d(var(--left-1), 0, 0) scale(var(--scale))
                rotate(var(--rotation));
            opacity: 0;
        }
    }
</style>

<style is:global>
    .slide {
        opacity: 0;
        width: 100%;
        height: 100%;
        grid-area: 2 / 1;
        position: relative;
        top: 0;
        left: 0;
        z-index: 0;
        transition: opacity 0.5s ease-in-out;
    }
    .slide.active {
        opacity: 1;
        z-index: 1;
    }

    .card-inner {
        width: 100%;
        background: rgba(1, 55, 123, 0.4);
        height: 100%;
        min-height: 60dvh;
        display: flex;
        flex-direction: column;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        overflow: hidden;
        position: relative;
    }

    .card-image {
        width: 100%;
        height: 100%;
        overflow: hidden;
        position: absolute;
        inset: 0;
        z-index: -1;
        border-radius: 20px;
    }

    .card-image .fuzzy-load {
        width: 100%;
        height: 100%;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover; /* fill parent without squishing */
        object-position: center; /* keep crop centered */
        opacity: 0;
        transition: opacity 1000ms ease-in-out;
        position: relative;
        z-index: 2;
    }

    .card-inner .header-row {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
    }

    .card-inner hgroup {
        padding: 1rem 2rem 0;
        max-width: 60%;
    }

    .card-inner hgroup h3 {
        text-shadow:
            0 6px 6px rgba(0, 0, 0, 0.3),
            0 0 28px var(--color-secondary-dark),
            0 0 14px var(--color-secondary-darker);
        color: var(--color-foreground);
        margin-bottom: 0.5rem;
    }

    .card-inner hgroup p {
        font-weight: var(--weight-medium);
        text-shadow: 2px 2px 2px var(--color-secondary-darker);
        text-align: left;
        color: white;
        margin: 0;
        line-height: 1.25;
    }

    .card-inner .stinger {
        background: rgba(255, 255, 255, 0.1);
        padding: 1rem clamp(1rem, 2vw, 2rem);
        max-width: 35%;
        text-align: right;
        background: linear-gradient(
            to left,
            rgba(1, 30, 68, 1) 0%,
            rgba(1, 30, 68, 0) 100%
        );
        font-family: var(--family-heading);
        text-shadow: 2px 2px 4px var(--color-secondary-darker);
        align-self: flex-start;
    }

    .card-inner .stinger p {
        margin: 0;
        line-height: 1.25em;
    }

    .card-inner .stinger p:nth-of-type(2) {
        margin-top: 1rem;
    }

    .card-inner .stinger span {
        color: var(--color-accent);
        font-weight: var(--weight-bold);
    }

    .card-inner .body-row {
        padding: 0 2rem;
    }

    .card-inner .footer-row {
        padding: 1rem 2rem;
        text-align: center;
        font-weight: var(--weight-bold);
        text-shadow: 2px 2px 4px var(--color-secondary-darker);
        margin: 0 clamp(1rem, 4vw, 4rem);
        border-top: 1px solid transparent;
        border-image: linear-gradient(
                to right,
                transparent 0%,
                var(--color-accent) 25%,
                var(--color-accent) 75%,
                transparent 100%
            )
            1;
    }

    @media (orientation: portrait), (width < 768px) {
        .card-inner .header-row {
            display: flex;
            flex-direction: column;
            margin-bottom: 1rem;
        }

        .card-inner .header-row p {
            text-align: center;
            max-width: 100%;
        }

        .card-inner hgroup {
            padding: 1rem 1rem 0;
            max-width: 100%;
            text-align: center;
        }

        .card-inner .stinger {
            display: none !important;
        }

        .card-inner .stinger p:nth-of-type(2) {
            margin-top: 0;
            margin-bottom: 1rem;
        }
    }
</style>

<script>
    import { FuzzyLoad } from "../../scripts/FuzzyLoad.js";
    document.addEventListener("astro:page-load", () => {
        document.querySelectorAll(".fuzzy-load").forEach((fuzzyLoadEl) => {
            new FuzzyLoad(fuzzyLoadEl);
        });
    });
</script>
