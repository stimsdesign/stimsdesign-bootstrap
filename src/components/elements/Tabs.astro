---
/*************************************************************************
 * @elements/Tabs.astro
 * -----------------------------------------------------------------------
 *
 * NOTE: To style the active (selected) tab, use the selector:
 * .tab-item:has(.tab-input:checked) .tab-label { ... }
 * This targets the label of the tab whose hidden radio input is checked.
 *
 * 
 * Description:
 *  A container component for grouping individual Tab triggers.
 *  Uses Astro.locals context to pass down the index to its children.
 * 
 * Usage:
 *  <Tabs id="services">
 *      <Tab name="services-tab" group="services">Services</Tab>
 *      <Tab name="projects-tab" group="services">Projects</Tab>
 *  </Tabs>
 * 
 *************************************************************************/

// Import → Styles
import "@theme/elements/Tabs.css";

interface Props {
    /** The unique identifier for this tab group (matches Tab's 'group') */
    id?: string;
    class?: string;
    [key: string]: any;
}

const { id, class: className = "", ...rest } = Astro.props;

// Pass grouping and counter down to children via Astro.locals (cast as any to avoid global env typings)
const locals = Astro.locals as any;
locals.currentTabGroup = id || "default-tabs-group";
locals.tabIndex = 0;
---

<div id={id} class:list={["tabs-group-container", className]} {...rest}>
    <div class="tabs-nav" role="tablist">
        <slot />
    </div>
</div>