---
/*************************************************************************
 * @elements/Slider.astro
 * -----------------------------------------------------------------------
 * 
 * Description: 
 *   A responsive slider/carousel component supporting touch/swipe events,
 *   autoplay, manual navigation arrows, and pagination bullets.
 * 
 * Usage:
 *   <Slider id="my-slider" arrows={true} pagination={true} bullets={3}>
 *      <div class="slide">Slide 1</div>
 *      <div class="slide">Slide 2</div>
 *      <div class="slide">Slide 3</div>
 *   </Slider>
 * 
 *************************************************************************/

// Import → Styles
import "@theme/elements/Slider.css";

// Import → Elements
import Icon from "@elements/SVGicon.astro";

// Props
interface Props {
    /** The unique HTML identifier for the slider component. */
    id?: string;
    /** Whether to show next/previous navigation arrows. Default: false. */
    arrows?: boolean;
    /** Whether to show pagination bullets. Default: false. */
    pagination?: boolean;
    /** The number of slides/bullets to generate in pagination. Default: 3. */
    bullets?: number;
    /** CSS color for the pagination bullets. Default: "white". */
    bulletColor?: string;
    /** Headers associated with slides for tab-like navigation. */
    headers?: string[];
    /** Whether the slider should automatically cycle through slides. Default: false. */
    autoplay?: boolean;
    /** Additional CSS classes. */
    class?: string;
    [key: string]: any;
}

// Destructuring Props
const {
    id,
    arrows = false,
    pagination = false,
    bullets = 3,
    bulletColor = "white",
    autoplay = false,
    class: className,
    ...rest
} = Astro.props;
---

<slider-component id={id} class:list={[{ autoplay: autoplay }, className]} {...rest}>
    {arrows && (<Icon name="arrow-left" class="slider-arrow arrow-left" />)}
        <div class="slides">
            <slot />
        </div>
    {arrows && (<Icon name="arrow-right" class="slider-arrow arrow-right" />)}
    {pagination && (
        <div class="pagination">
            {Array.from({ length: bullets }).map((_, i) => (
                <span class="pagination-bullet" data-index={i} style={`color: ${bulletColor};`} />
            ))}
        </div>
    )}
</slider-component>

<script>
    import "@scripts/Slider.js";
</script>