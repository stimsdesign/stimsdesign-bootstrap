---

---

<script>
    import { setCookie, getCookie } from "../../scripts/Utils.js";

    class AnnouncementBar {
        root: HTMLElement;
        closeBtn: HTMLElement | null;
        sliderEl: HTMLElement | null;
        content: HTMLElement | null;
        leftArrow: HTMLElement | null;
        rightArrow: HTMLElement | null;
        slides: HTMLElement[];
        allSlides: HTMLElement[] = [];
        originalCount: number;
        slideWidth: number;
        autoPlayTimer: any | null;
        mobileTimer: any | null;
        isMobile: boolean;
        currentIndex: number;
        mode: string;
        onResize?: () => void;
        resizeDebounce: any;

        constructor(root: Element) {
            this.root = root as HTMLElement;
            this.closeBtn = root.querySelector(
                "#announcement-bar-close",
            ) as HTMLElement | null;
            this.sliderEl = root.querySelector(
                ".announcement-bar-slider",
            ) as HTMLElement | null;
            this.content = root.querySelector(
                ".announcement-bar-content",
            ) as HTMLElement | null;
            this.leftArrow = root.querySelector(
                ".arrow-button.left-arrow",
            ) as HTMLElement | null;
            this.rightArrow = root.querySelector(
                ".arrow-button.right-arrow",
            ) as HTMLElement | null;
            this.slides = this.content
                ? (Array.from(
                      this.content.querySelectorAll("span"),
                  ) as HTMLElement[])
                : [];
            this.originalCount = this.slides.length;
            this.slideWidth = 400; // mirrors legacy constant

            this.autoPlayTimer = null;
            this.mobileTimer = null;

            this.isMobile = (window as any).IS_MOBILE;
            this.currentIndex = this.isMobile ? 0 : 1;
            this.mode = this.isMobile ? "mobile" : "desktop";

            if (!getCookie("announcementBarClosed")) {
                this.root.style.display = "flex";
                this.init();
                this.bindResize();
            } else {
                this.root.style.display = "none";
            }
        }

        init() {
            this.bindClose();
            if (!this.slides.length) return;
            if (this.isMobile) {
                this.initMobile();
            } else if (this.originalCount > 1) {
                this.initDesktop();
            }
        }

        bindClose() {
            if (!this.closeBtn) return;
            this.closeBtn.addEventListener("click", () => {
                this.root.style.display = "none";
                setCookie("announcementBarClosed", "true", 1);
                this.destroy();
            });
        }

        bindResize() {
            this.onResize = () => {
                // Wait for global debounced setter to update window.IS_MOBILE
                clearTimeout(this.resizeDebounce);
                this.resizeDebounce = setTimeout(() => {
                    const newIsMobile = (window as any).IS_MOBILE;
                    if (newIsMobile !== this.isMobile) {
                        this.isMobile = newIsMobile;
                        this.switchMode();
                    }
                }, 200);
            };
            window.addEventListener("resize", this.onResize);
        }

        switchMode() {
            this.stopAuto();
            if (this.mobileTimer) {
                clearInterval(this.mobileTimer);
                this.mobileTimer = null;
            }
            this.resetSlides();
            this.cleanupClones();
            this.currentIndex = this.isMobile ? 0 : 1;
            this.mode = this.isMobile ? "mobile" : "desktop";

            // Hide arrows in mobile, show in desktop (handled again in initDesktop)
            if (this.leftArrow)
                this.leftArrow.style.display = this.isMobile ? "none" : "";
            if (this.rightArrow)
                this.rightArrow.style.display = this.isMobile ? "none" : "";

            if (this.isMobile) {
                this.initMobile();
            } else if (this.originalCount > 1) {
                this.initDesktop();
            } else {
                // Single slide desktop fallback
                this.slides.forEach((s) => {
                    s.style.opacity = "1";
                    s.style.position = "";
                });
            }
        }

        resetSlides() {
            // Remove inline styles applied in either mode
            this.slides.forEach((slide) => {
                slide.style.position = "";
                slide.style.top = "";
                slide.style.left = "";
                slide.style.opacity = "";
                slide.style.transition = "";
            });
            if (this.content) {
                this.content.style.transition = "";
                this.content.style.transform = "";
            }
        }

        cleanupClones() {
            if (!this.content) return;
            // Remove first and last if clones exist (length > originalCount)
            let spans = Array.from(
                this.content.querySelectorAll("span"),
            ) as HTMLElement[];
            while (spans.length > this.originalCount) {
                // Remove first
                if (spans.length > this.originalCount) spans[0].remove();
                spans = Array.from(
                    this.content.querySelectorAll("span"),
                ) as HTMLElement[];
                // Remove last
                if (spans.length > this.originalCount)
                    spans[spans.length - 1].remove();
                spans = Array.from(
                    this.content.querySelectorAll("span"),
                ) as HTMLElement[];
            }
            this.slides = Array.from(
                this.content.querySelectorAll("span"),
            ) as HTMLElement[];
            this.allSlides = this.slides;
        }

        // Desktop slider
        initDesktop() {
            if (this.leftArrow) this.leftArrow.style.display = "flex";
            if (this.rightArrow) this.rightArrow.style.display = "flex";

            this.slides.forEach((s) => {
                s.style.opacity = "1";
                s.style.position = "";
            });

            // clone first and last (only if not already cloned)
            if (
                this.content &&
                this.content.querySelectorAll("span").length ===
                    this.originalCount
            ) {
                const firstClone = this.slides[0].cloneNode(
                    true,
                ) as HTMLElement;
                const lastClone = this.slides[this.slides.length - 1].cloneNode(
                    true,
                ) as HTMLElement;
                this.content.appendChild(firstClone);
                this.content.insertBefore(lastClone, this.slides[0]);
            }

            if (this.content) {
                this.allSlides = Array.from(
                    this.content.querySelectorAll("span"),
                ) as HTMLElement[];
            }
            this.setTransform();

            this.autoPlayTimer = setInterval(() => this.next(), 4000);

            if (this.leftArrow) {
                this.leftArrow.onclick = () => {
                    this.stopAuto();
                    this.prev();
                };
            }
            if (this.rightArrow) {
                this.rightArrow.onclick = () => {
                    this.stopAuto();
                    this.next();
                };
            }
        }

        setTransform(animate = true) {
            if (!this.content) return;
            this.content.style.transition = animate
                ? "transform 0.5s ease-in-out"
                : "none";
            this.content.style.transform = `translateX(-${this.currentIndex * this.slideWidth}px)`;
        }

        next() {
            this.currentIndex++;
            this.moveWithLoopCheck();
        }

        prev() {
            this.currentIndex--;
            this.moveWithLoopCheck();
        }

        moveWithLoopCheck() {
            if (!this.content) return;
            this.setTransform(true);
            const onEnd = () => {
                if (this.currentIndex === this.originalCount + 1) {
                    this.currentIndex = 1;
                    this.setTransform(false);
                } else if (this.currentIndex === 0) {
                    this.currentIndex = this.originalCount;
                    this.setTransform(false);
                }
                this.content!.removeEventListener("transitionend", onEnd);
            };
            this.content.addEventListener("transitionend", onEnd);
        }

        stopAuto() {
            if (this.autoPlayTimer) {
                clearInterval(this.autoPlayTimer);
                this.autoPlayTimer = null;
            }
        }

        // Mobile cross-fade
        initMobile() {
            this.slides.forEach((slide) => {
                slide.style.position = "absolute";
                slide.style.top = "0";
                slide.style.left = "0";
                slide.style.opacity = "0";
                slide.style.transition = "opacity 0.5s ease";
            });
            this.showMobileSlide(this.currentIndex);
            this.mobileTimer = setInterval(() => {
                this.slides[this.currentIndex].style.opacity = "0";
                this.currentIndex =
                    (this.currentIndex + 1) % this.slides.length;
                this.showMobileSlide(this.currentIndex);
            }, 4000);
        }

        showMobileSlide(i: number) {
            this.slides.forEach((s, idx) => {
                if (idx === i) s.style.opacity = "1";
            });
        }

        destroy() {
            this.stopAuto();
            if (this.mobileTimer) {
                clearInterval(this.mobileTimer);
                this.mobileTimer = null;
            }
            if (this.onResize) {
                window.removeEventListener("resize", this.onResize);
            }
        }
    }
    document.addEventListener(
        "astro:page-load",
        () => {
            const bar = document.getElementById("announcement-bar");
            if (bar) new AnnouncementBar(bar);
        },
        { passive: true },
    );
</script>
