---
interface Props {
    color?: string;
}

const { color = "black" } = Astro.props;
---

<div class="waves">
    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
        <defs>
            <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z"></path>
        </defs>
        <g class="parallax">
            <use class="wave1" xlink:href="#gentle-wave" x="48" y="0" fill="currentColor" style={`color: ${color};`}></use>
            <use class="wave2" xlink:href="#gentle-wave" x="48" y="3" fill="currentColor" style={`color: ${color};`}></use>
            <use class="wave3" xlink:href="#gentle-wave" x="48" y="5" fill="currentColor" style={`color: ${color};`}></use>
            <use class="wave4" xlink:href="#gentle-wave" x="48" y="7" fill="currentColor" style={`color: ${color};`}></use>
        </g>
    </svg>
</div>
