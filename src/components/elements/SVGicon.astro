---
/*************************************************************************
 * @elements/SVGicon.astro
 * -----------------------------------------------------------------------
 * 
 * Description: 
 *   Consumption component for UI icons. Resolves individual SVG files 
 *   at build time and references them via a global SVG sprite sheet (SVGiconSheet).
 *   Supports subdirectories and auto-stripping of the .svg extension.
 * 
 * Usage:
 *   <SVGicon name="arrow-right" class="icon-class" />
 *   <SVGicon name="brands/facebook.svg" class="icon-class" />
 * 
 *************************************************************************/

// Props
interface Props {
  /** Optional HTML identifier for the SVG element. */
  id?: string;
  /** Name of the icon SVG file in `src/assets/images/icons/` */
  name: string;
  /** Additional CSS classes. */
  class?: string;
  [key: string]: any;
}

// Props Destructuring
const { id, name, class: className, ...rest } = Astro.props;

// Strip .svg extension if present
const cleanName = name.replace(/\.svg$/, "");

// Glob SVG Files recursively
const iconFiles = import.meta.glob("@images/icons/**/*.svg", {
    query: "?raw",
    eager: true,
});

// Add icon to registry
if (!Astro.locals.iconRegistry) Astro.locals.iconRegistry = new Set();
Astro.locals.iconRegistry.add(cleanName);

// Import SVG Markup
const iconPath = Object.keys(iconFiles).find(path => path.endsWith(`/icons/${cleanName}.svg`));
const raw = iconPath ? (iconFiles[iconPath] as any)?.default : null;

// Extract and normalize viewBox (shift origin to 0,0)
const viewBoxRaw = raw?.match(/viewBox\s*=\s*["']([^"']+)["']/i)?.[1];
let viewBox = viewBoxRaw;
if (viewBoxRaw) {
    const parts = viewBoxRaw.split(/\s+/);
    if (parts.length === 4) {
        // Keep width and height, but force origin to 0 0
        viewBox = `0 0 ${parts[2]} ${parts[3]}`;
    }
}

// Warning if icon is not found or has incompatible format
if (import.meta.env.DEV) {
    if (!raw) {
        console.warn(`[Icon] Icon "${name}" not found in src/assets/images/icons/`);
    } else {
        const svgMatch = raw.match(/<svg([^>]*)>([\s\S]*)<\/svg>/i);
        if (!svgMatch) {
            console.warn(`[Icon] Icon "${name}" in src/assets/images/icons/ is not a compatible SVG file format.`);
        }
    }
}
---

<svg 
    id={id}
    class={className} 
    viewBox={viewBox} 
    fill="currentColor" 
    {...rest}
>
  <use href={`#icon-${cleanName}`} />
</svg>
