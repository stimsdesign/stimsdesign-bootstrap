---
/*************************************************************************
 * @elements/SVGsprite.astro
 * -----------------------------------------------------------------------
 * 
 * Description: 
 *   Consumption component for general images/illustrations. Resolves individual 
 *   SVG files at build time and references them via a global SVG sprite sheet (SVGspriteSheet).
 *   Supports subdirectories and auto-stripping of the .svg extension.
 * 
 * Usage:
 *   <SVGsprite name="illustration-hero" class="sprite-class" />
 *   <SVGsprite name="brands/Orenda.svg" class="sprite-class" />
 * 
 *************************************************************************/

// Props
interface Props {
  /** Optional HTML identifier for the SVG element. */
  id?: string;
  /** Name of the sprite SVG file in `src/assets/images/sprites/` */
  name: string;
  /** Additional CSS classes. */
  class?: string;
  [key: string]: any;
}

// Props Destructuring
const { id, name, class: className, ...rest } = Astro.props;

// Strip .svg extension if present
const cleanName = name.replace(/\.svg$/, "");

// Glob SVG Files recursively
const spriteFiles = import.meta.glob("@images/sprites/**/*.svg", {
    query: "?raw",
    eager: true,
});

// Add sprite to registry
if (!Astro.locals.spriteRegistry) Astro.locals.spriteRegistry = new Set();
Astro.locals.spriteRegistry.add(cleanName);

// Import SVG Markup
const spritePath = Object.keys(spriteFiles).find(path => path.endsWith(`/sprites/${cleanName}.svg`));
const raw = spritePath ? (spriteFiles[spritePath] as any)?.default : null;

// Extract and normalize viewBox (shift origin to 0,0)
const viewBoxRaw = raw?.match(/viewBox\s*=\s*["']([^"']+)["']/i)?.[1];
let viewBox = viewBoxRaw;
if (viewBoxRaw) {
    const parts = viewBoxRaw.split(/\s+/);
    if (parts.length === 4) {
        viewBox = `0 0 ${parts[2]} ${parts[3]}`;
    }
}

// Warning if sprite not found or has incompatible format
if (import.meta.env.DEV) {
    if (!raw) {
        console.warn(`[Sprite] Sprite "${name}" not found in src/assets/images/sprites/`);
    } else {
        const svgMatch = raw.match(/<svg([^>]*)>([\s\S]*)<\/svg>/i);
        if (!svgMatch) {
            console.warn(`[Sprite] Sprite "${name}" in src/assets/images/sprites/ is not a compatible SVG file format.`);
        }
    }
}
---

<svg id={id} class={className} viewBox={viewBox} {...rest}>
  <use href={`#sprite-${cleanName}`} />
</svg>
