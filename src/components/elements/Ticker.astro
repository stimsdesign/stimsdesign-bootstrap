<div class="ticker-wrapper">
    <span class="ticker-label"><span class="fire">Tech Stack</span></span>
    <div class="ticker">
        <div class="ticker-runner">
            <div class="ticker__item">
                <slot />
            </div>
        </div>
    </div>
</div>

<style is:global>
    div.ticker-wrapper {
        position: relative;
        width: 100%;
        background-color: var(--color-secondary-dark);
    }
    .ticker {
        overflow: hidden;
        width: clamp(94%, 100% - 10cqi, 1440px);
        margin: 0 auto 0;
        background-color: var(--color-background);
        border-radius: 6px;
        -webkit-touch-callout: none;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
        -webkit-user-drag: none;
        -webkit-tap-highlight-color: transparent;
    }

    .ticker-label {
        display: block;
        grid-column: 1 / -1;
        margin: 0 auto;
        padding: 0.25rem 0.5rem 0;
        border-radius: 5px 5px 0 0;
        width: fit-content;
        background-color: var(--color-background);
        font-size: var(--size-sm);
        font-weight: var(--weight-medium);
        color: var(--color-accent);
    }

    .ticker .ticker-runner {
        display: flex;
        width: max-content;
        animation: ticker-scroll 90s linear infinite;
    }

    .ticker__item {
        white-space: nowrap;
    }

    .ticker__item span {
        display: inline-block;
        margin: 0 1rem;
        padding: 1rem 0 1rem calc(0.5rem + 40px);
        font-size: var(--size-lg);
        font-weight: var(--weight-medium);
        position: relative;
    }

    .ticker__item span::before {
        content: "";
        display: block;
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 40px;
        height: 40px;
        background-size: contain;
    }

