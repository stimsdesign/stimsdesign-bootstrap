<script>
    class Ticker {
        runner: HTMLElement | null;
        item: HTMLElement | null;

        constructor(root: Element) {
            this.runner = root.querySelector(".ticker-runner");
            this.item = this.runner?.querySelector(".ticker__item") || null;
            if (!this.runner || !this.item) return;
            this.cloneItems();
        }
        cloneItems() {
            if (!this.runner || !this.item) return;
            for (let i = 0; i < 3; i++) {
                this.runner.appendChild(this.item.cloneNode(true));
            }
        }
    }

    document.addEventListener(
        "astro:page-load",
        () => {
            const tickers = document.querySelectorAll(".ticker");
            tickers.forEach((ticker) => new Ticker(ticker));
        },
        { passive: true },
    );
</script>
