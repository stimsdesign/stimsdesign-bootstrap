---
/*************************************************************************
 * @elements/GoogleMap.astro
 * -----------------------------------------------------------------------
 * 
 * Description: 
 *   A custom Google Map embed component that lazily loads an iframe on 
 *   screens wider than 768px (tablets/desktops) to optimize performance.
 *   Uses a custom element to work seamlessly with Astro's View Transitions.
 * 
 * Usage:
 *   - Default (Uses site configuration address):
 *       <GoogleMap />
 * 
 *   - Custom Location & Satellite Style:
 *       <GoogleMap query="Grand Canyon, AZ" zoom={14} mapType="satellite" />
 * 
 *************************************************************************/

// Import → Site Config
import { Site } from "@site.config";

// Import → Styles
import "@theme/elements/GoogleMap.css";

// Interface Props
interface Props {
    /** Custom query (e.g., address, coordinates "40.7128,-74.006", or place name). Defaults to Site Brand + Address config. */
    query?: string;
    /** Zoom level (1 to 21). Default: 10 (regional view). */
    zoom?: number | string;
    /** The style of map display. Options: "roadmap", "satellite", "hybrid", "terrain". Default: "roadmap". */
    mapType?: "roadmap" | "satellite" | "hybrid" | "terrain";
    /** Map UI and label language (e.g., "en", "es", "fr"). Default: "en". */
    lang?: string;
    /** Additional CSS classes. */
    class?: string;
    [key: string]: any;
}

// Destructuring Props with Default Values
const { 
    query = `${Site.Brand}, ${Site.AddressLine1}, ${Site.City}, ${Site.State} ${Site.PostalCode}`,
    zoom = 10,
    mapType = "roadmap",
    lang = "en",
    class: className, 
    ...rest 
} = Astro.props;

// Map mapType to Google Maps URL parameters
const typeMap = {
    roadmap: "",
    satellite: "k",
    hybrid: "h",
    terrain: "p"
};
const t = typeMap[mapType] ?? "";

// Construct final Map Embed URL (No API key required for basic embed)
const encodedQuery = encodeURIComponent(query);
const mapUrl = `https://maps.google.com/maps?width=100%25&height=100%25&hl=${lang}&q=${encodedQuery}&t=${t}&z=${zoom}&ie=UTF8&iwloc=B&output=embed`;
---
<google-map class:list={["google-map-container", className]} {...rest}>
    <iframe 
        data-src={mapUrl}
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        title={`Google Map showing service area for ${Site.Brand}`}
    ></iframe>
</google-map>

<script>
    import "@scripts/GoogleMap.js";
</script>