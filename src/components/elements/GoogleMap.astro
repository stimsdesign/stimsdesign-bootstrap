---
import { Site } from "@site.config";

// Construct the full address from site configuration
const address = `${Site.AddressLine1}, ${Site.City}, ${Site.State} ${Site.PostalCode}`;

// Encode the address and brand name for the URL query
const encodedQuery = encodeURIComponent(`${Site.Brand}, ${address}`);

// Google Maps Embed URL (No API key required for basic embed)
// Using z=10 provides a regional zoom level that nicely encompasses the Wasatch Front
const mapUrl = `https://maps.google.com/maps?width=100%25&height=100%25&hl=en&q=${encodedQuery}&t=&z=10&ie=UTF8&iwloc=B&output=embed`;
interface Props {
    class?: string;
    [key: string]: any;
}

const { class: className, ...rest } = Astro.props;
---

<div class:list={["google-map-container", className]} id="google-map-wrapper" {...rest}>
    <iframe 
        data-src={mapUrl}
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
        title={`Google Map showing service area for ${Site.Brand}`}
        id="google-map-iframe"
    ></iframe>
</div>

<script is:inline>
    (function() {
        const wrapper = document.getElementById('google-map-wrapper');
        const iframe = document.getElementById('google-map-iframe');
        
        function loadMap() {
            if (window.innerWidth > 768) {
                if (iframe && iframe.dataset.src && !iframe.src) {
                    iframe.src = iframe.dataset.src;
                }
            } else {
                // On mobile, we might want to hide it or keep it as a placeholder
                // For now, let's just not load the heavy iframe
                if (wrapper) {
                     wrapper.style.display = 'none';
                     // Notify parent to hide the container if needed
                     const parent = wrapper.closest('#service-area__map');
                     if (parent) parent.style.display = 'none';
                }
            }
        }

        loadMap();
        // Optional: reload on resize if needed, but usually once is enough for perf
    })();
</script>

<style>
    .google-map-container {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background-color: #e0e0e0;
        position: relative;
        z-index: 500;
    }

    @media (max-width: 769px) {
        .google-map-container {
            display: none;
        }
    }

    iframe {
        border: none;
        width: 100%;
        height: 100%;
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        background: transparent;
    }
</style>
