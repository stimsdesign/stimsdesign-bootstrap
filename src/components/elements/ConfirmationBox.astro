---
/*************************************************************************
 * @elements/ConfirmationBox.astro
 * -----------------------------------------------------------------------
 * 
 * Description: 
 *   A reusable confirmation box component.
 * 
 * Usage:
 *   Add the component to your page/layout:
 *   <ConfirmationBox />
 * 
 * Triggering from any element:
 *   - Add the class `.open-confirmation` to the trigger element.
 *   - Use data attributes for content:
 *     - data-modal-header: Text for the title
 *     - data-modal-paragraph: Text for the message
 *     - data-modal-button: Text for the close button
 * 
 *   Example:
 *   <button 
 *      class="open-confirmation" 
 *      data-modal-header="Are you sure?" 
 *      data-modal-paragraph="This action cannot be undone."
 *      data-modal-button="Got it"
 *   >
 *      Trigger Action
 *   </button>
 * 
 *************************************************************************/

// Import → Site Config
import { Site } from "@site.config";

// Import → Styles
import "@theme/elements/ConfirmationBox.css";

// Import → Components
import Button from "@elements/Button.astro";

// Props
interface Props {
    /** Additional CSS classes. */
    class?: string;
    [key: string]: any;
}

// Destructuring Props
const { class: className, ...rest } = Astro.props;
---
<confirmation-box id="confirmation-box" class:list={["is-wrapper", className]} {...rest}>
    <slot>
        <div class="content">
            <h2 data-modal-title>{Site.Company}</h2>
            <p data-modal-text>{Site.Mission}</p>
            <Button class="close-modal" data-modal-close>Close</Button>
        </div>
    </slot>
</confirmation-box>

<script>
    import "@scripts/ConfirmationBox.js";
</script>
