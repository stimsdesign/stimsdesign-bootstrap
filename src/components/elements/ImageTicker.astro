---
/*************************************************************************
 * @elements/ImageTicker.astro
 * -----------------------------------------------------------------------
 * 
 * Description: 
 *   An infinite scrolling image/logo ticker component. Loops through its
 *   child elements and clones them for seamless horizontal scrolling.
 *   Uses a custom element to work cleanly with Astro's View Transitions.
 * 
 * Usage:
 *   - Default Setup:
 *       <ImageTicker>
 *           <img src="/image1.png" alt="1" />
 *           <img src="/image2.png" alt="2" />
 *       </ImageTicker>
 * 
 *   - Custom configuration defaults (Speed, Direction, Spacing, Height):
 *       <ImageTicker 
 *           speed="medium" 
 *           direction="left" 
 *           itemHeight="5cqi" 
 *           gap="2cqi" 
 *           pauseOnHover={false}
 *       >
 *           ...
 *       </ImageTicker>
 * 
 *************************************************************************/

// Import → Styles
import "@theme/elements/ImageTicker.css";

interface Props {
    /** Pause scrolling on mouse hover. Default: true */
    pauseOnHover?: boolean;
    /** Animation scroll duration in seconds (e.g. 60) or preset ("slow", "medium", "fast"). Default: "medium" (90s) */
    speed?: "slow" | "medium" | "fast" | number;
    /** Direction of scroll. Options: "left" | "right". Default: "left" */
    direction?: "left" | "right";
    /** Spacing between items. Default: "2cqi" */
    gap?: string;
    /** Height of items. Default: "5cqi" */
    itemHeight?: string;
    class?: string;
    [key: string]: any;
}

const { 
    pauseOnHover = false,
    speed = "medium",
    direction = "left",
    gap = "2cqi",
    itemHeight = "5cqi",
    class: className, 
    ...rest 
} = Astro.props;

// Speed presets mapping
const speedMap = {
    slow: "120s",
    medium: "90s",
    fast: "45s"
};
const duration = typeof speed === "number" ? `${speed}s` : (speedMap[speed] || "90s");
---
<image-ticker 
    class:list={["image-ticker__wrapper", className]} 
    data-pause-on-hover={pauseOnHover ? "" : undefined}
    data-direction={direction}
    style={{
        "--ticker-duration": duration,
        "--ticker-gap": gap,
        "--ticker-height": itemHeight
    }}
    {...rest}
>
    <div class="image-ticker">
        <div class="image-ticker__runner">
            <div class="image-ticker__img">
                <slot />
            </div>
        </div>
    </div>
</image-ticker>

<script>
    import "@scripts/ImageTicker.js";
</script>
