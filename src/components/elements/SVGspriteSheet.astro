---
/*************************************************************************
 * @elements/SVGspriteSheet.astro
 * -----------------------------------------------------------------------
 * 
 * Description: 
 *   Generates a global SVG sprite sheet for general illustrations by scanning the 
 *   `spriteRegistry` populated by SVGsprite components during SSR.
 *   Supports subdirectories under src/assets/images/sprites/.
 * 
 * Usage:
 *   Include this component once in your main layout (typically at the bottom of the body):
 *   <SVGspriteSheet />
 * 
 *************************************************************************/

// Get registered sprites
const registered = Astro.locals.spriteRegistry || new Set();

// Glob all SVGs as raw strings recursively from the images directory
const spriteFiles = import.meta.glob("../../assets/images/sprites/**/*.svg", {
    query: "?raw",
    eager: true,
});

// SVG symbols defs
const allDefs: string[] = [];

// Process each SVG
function processSvg(raw: any, path: string) {
    const baseSegment = "/sprites/";
    const index = path.indexOf(baseSegment);
    let name = "";
    if (index !== -1) {
        name = path.substring(index + baseSegment.length).replace(/\.svg$/, "");
    } else {
        name = path.split("/").pop()?.replace(/\.svg$/, "") || "";
    }

    // Only process if it was requested
    if (!registered.has(name)) return null;

    let content = raw;
    
    // Remove XML declaration and comments
    content = content.replace(/<\?xml.*\?>/g, "").replace(/<!--.*-->/g, "").trim();

    // Extract attributes and body
    const svgMatch = content.match(/<svg([^>]*)>([\s\S]*)<\/svg>/i);
    if (!svgMatch) return null;

    let attributes = svgMatch[1];
    let body = svgMatch[2];

    // Remove width/height from attributes
    attributes = attributes.replace(/\s+(width|height)\s*=\s*["']([^"']*)["']/gi, "");

    // 1. Extract <defs> and prefix their internal IDs
    const defsMatch = body.match(/<defs>([\s\S]*?)<\/defs>/);
    if (defsMatch) {
        let defs = defsMatch[1];
        defs = defs.replace(/id="([^"]+)"/g, (_: string, id: string) => `id="sprite-${name}-${id}"`);
        allDefs.push(defs);
        body = body.replace(/<defs>[\s\S]*?<\/defs>/, "");
    }

    // 2. Prefix references and IDs in the body
    body = body.replace(/url\(#([^)]+)\)/g, (_: string, id: string) => `url(#sprite-${name}-${id})`);
    body = body.replace(/href="#([^"]+)"/g, (_: string, id: string) => `href="#sprite-${name}-${id}"`);
    body = body.replace(/xlink:href="#([^"]+)"/g, (_: string, id: string) => `xlink:href="#sprite-${name}-${id}"`);
    body = body.replace(/id="([^"]+)"/g, (_: string, id: string) => `id="sprite-${name}-${id}"`);

    // 3. Return as symbol
    return `<symbol id="sprite-${name}"${attributes}>${body}</symbol>`;
}

// Process and collect symbols
const symbols = Object.entries(spriteFiles)
    .map(([path, module]: any) => processSvg(module.default, path))
    .filter((s): s is string => s !== null);
---

<svg id="sprite-sheet" xmlns="http://www.w3.org/2000/svg" class="hidden" aria-hidden="true">
    {allDefs.length > 0 && <defs set:html={allDefs.join("\n")} />}
    {symbols.map((symbol) => (
        <Fragment set:html={symbol} />
    ))}
</svg>
