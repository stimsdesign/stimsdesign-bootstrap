---
/*************************************************************************
 * @elements/TextTicker.astro
 * -----------------------------------------------------------------------
 * 
 * Description: 
 *   An infinite scrolling text ticker component. Loops through its
 *   child elements (spans) and clones them for seamless horizontal scrolling.
 *   Automatically assigns clean, lowercase, hyphenated CSS classes to
 *   internal spans matching their text content.
 *   Uses a custom element to work cleanly with Astro's View Transitions.
 * 
 * Usage:
 *   - Default Setup:
 *       <TextTicker>
 *           <span>Shopify</span>
 *           <span>Astro</span>
 *       </TextTicker>
 * 
 *   - Custom configurations (Speed, Direction, Spacing):
 *       <TextTicker 
 *           speed="medium" 
 *           direction="left" 
 *           gap="0.5ch" 
 *           pauseOnHover={false}
 *       >
 *           ...
 *       </TextTicker>
 * 
 *************************************************************************/

// Import → Styles
import "@theme/elements/TextTicker.css";

interface Props {
    /** Pause scrolling on mouse hover. Default: false */
    pauseOnHover?: boolean;
    /** Animation scroll duration in seconds (e.g. 60) or preset ("slow", "medium", "fast"). Default: "medium" (90s) */
    speed?: "slow" | "medium" | "fast" | number;
    /** Direction of scroll. Options: "left" | "right". Default: "left" */
    direction?: "left" | "right";
    /** Spacing between items. Default: "0.5ch" */
    gap?: string;
    class?: string;
    [key: string]: any;
}

const { 
    pauseOnHover = false,
    speed = "medium",
    direction = "left",
    gap = "0.5ch",
    class: className, 
    ...rest 
} = Astro.props;

// Speed presets mapping
const speedMap = {
    slow: "120s",
    medium: "90s",
    fast: "45s"
};
const duration = typeof speed === "number" ? `${speed}s` : (speedMap[speed] || "90s");
---
<text-ticker 
    class:list={["text-ticker__wrapper", className]} 
    data-pause-on-hover={pauseOnHover ? "" : undefined}
    data-direction={direction}
    style={{
        "--ticker-duration": duration,
        "--ticker-gap": gap
    }}
    {...rest}
>
    <div class="text-ticker">
        <div class="text-ticker__runner">
            <div class="text-ticker__item">
                <slot />
            </div>
        </div>
    </div>
</text-ticker>

<script>
    import "@scripts/TextTicker.js";
</script>
